#!/usr/bin/env bash
# Prism clean — 根据 prism.local.yaml 的 archived_skills 清理已分发的软链接。
#
# 用法:
#   bin/clean              清理所有 archived_skills 的软链接
#   bin/clean --dry-run    预览要删除的链接，不实际执行
#   bin/clean --list       仅列出 archived_skills 清单
#   bin/clean --add NAME   向 archived_skills 追加一个技能并清理
#   bin/clean --restore NAME  从 archived_skills 移除一个技能并 relink 恢复

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PRISM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG="$PRISM_DIR/prism.local.yaml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

DRY_RUN=false
LIST_ONLY=false
ADD_SKILL=""
RESTORE_SKILL=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)  DRY_RUN=true; shift ;;
    --list)     LIST_ONLY=true; shift ;;
    --add)
      [[ $# -lt 2 || -z "$2" ]] && { echo -e "${RED}✗ --add 需要技能名${NC}" >&2; exit 1; }
      ADD_SKILL="$2"; shift 2 ;;
    --restore)
      [[ $# -lt 2 || -z "$2" ]] && { echo -e "${RED}✗ --restore 需要技能名${NC}" >&2; exit 1; }
      RESTORE_SKILL="$2"; shift 2 ;;
    --help|-h)
      echo "用法: bin/clean [--dry-run|--list|--add NAME|--restore NAME]"
      echo "  (无参数)       清理所有 archived_skills 的软链接"
      echo "  --dry-run      预览要删除的链接"
      echo "  --list         列出当前 archived_skills"
      echo "  --add NAME     归档一个技能（追加到 yaml + 清理链接）"
      echo "  --restore NAME 恢复一个技能（从 yaml 移除 + relink）"
      exit 0 ;;
    *) echo "未知参数: $1"; exit 1 ;;
  esac
done

[[ -f "$CONFIG" ]] || { echo -e "${RED}✗ prism.local.yaml 不存在${NC}"; exit 1; }

# ── 解析 archived_skills ──
parse_archived() {
  local in_section=false
  while IFS= read -r line; do
    if [[ "$line" =~ ^archived_skills: ]]; then
      in_section=true; continue
    fi
    if $in_section; then
      if [[ "$line" =~ ^[[:space:]]+-[[:space:]]+(.*) ]]; then
        echo "${BASH_REMATCH[1]}"
      elif [[ ! "$line" =~ ^[[:space:]] && ! "$line" =~ ^$ && ! "$line" =~ ^# ]]; then
        break
      fi
    fi
  done < "$CONFIG"
}

ARCHIVED=()
while IFS= read -r name; do
  [[ -n "$name" ]] && ARCHIVED+=("$name")
done < <(parse_archived)

# ── --add: 追加技能到 archived_skills 并清理 ──
if [[ -n "$ADD_SKILL" ]]; then
  for existing in "${ARCHIVED[@]+"${ARCHIVED[@]}"}"; do
    if [[ "$existing" == "$ADD_SKILL" ]]; then
      echo -e "${YELLOW}⚠${NC} ${ADD_SKILL} 已在 archived_skills 中"
      exit 0
    fi
  done

  # 在 archived_skills 段末尾插入新条目
  tmp="${CONFIG}.tmp.$$"
  awk -v skill="$ADD_SKILL" '
    /^archived_skills:/ { in_section=1; print; next }
    in_section && /^[^ #]/ && !/^[[:space:]]/ {
      print "  - " skill
      in_section=0
    }
    { print }
    END { if (in_section) print "  - " skill }
  ' "$CONFIG" > "$tmp" && mv "$tmp" "$CONFIG"

  echo -e "${GREEN}✓${NC} 已将 ${CYAN}${ADD_SKILL}${NC} 加入 archived_skills"
  ARCHIVED+=("$ADD_SKILL")
fi

# ── --restore: 从 archived_skills 移除并 relink ──
if [[ -n "$RESTORE_SKILL" ]]; then
  found=false
  for existing in "${ARCHIVED[@]+"${ARCHIVED[@]}"}"; do
    [[ "$existing" == "$RESTORE_SKILL" ]] && found=true
  done
  if ! $found; then
    echo -e "${YELLOW}⚠${NC} ${RESTORE_SKILL} 不在 archived_skills 中"
    exit 0
  fi

  tmp="${CONFIG}.tmp.$$"
  awk -v skill="$RESTORE_SKILL" '
    /^[[:space:]]+-[[:space:]]+/ {
      gsub(/^[[:space:]]+-[[:space:]]+/, "", $0)
      if ($0 == skill) next
    }
    { print }
  ' "$CONFIG" > "$tmp" && mv "$tmp" "$CONFIG"

  echo -e "${GREEN}✓${NC} 已将 ${CYAN}${RESTORE_SKILL}${NC} 从 archived_skills 移除"
  echo -e "${DIM}运行 bin/relink 恢复该技能的软链接...${NC}"
  "$PRISM_DIR/bin/relink"
  exit 0
fi

# ── --list ──
if $LIST_ONLY; then
  echo -e "${CYAN}Archived Skills (${#ARCHIVED[@]})${NC}"
  if [[ ${#ARCHIVED[@]} -eq 0 ]]; then
    echo -e "  ${DIM}(空)${NC}"
  else
    for s in "${ARCHIVED[@]}"; do
      echo -e "  ${DIM}⊘${NC} $s"
    done
  fi
  exit 0
fi

# ── 探测平台目录 ──
PLATFORM_TARGETS=()
[[ -d "$HOME/.cursor/skills-cursor" ]] && PLATFORM_TARGETS+=("cursor|$HOME/.cursor/skills-cursor")
[[ -d "$HOME/.claude/skills" ]] && PLATFORM_TARGETS+=("claude|$HOME/.claude/skills")
[[ -d "$HOME/.claude-internal/skills" ]] && PLATFORM_TARGETS+=("claude-internal|$HOME/.claude-internal/skills")
[[ -d "$HOME/.codex/skills" ]] && PLATFORM_TARGETS+=("codex|$HOME/.codex/skills")
[[ -d "$HOME/.codebuddy/skills" ]] && PLATFORM_TARGETS+=("codebuddy|$HOME/.codebuddy/skills")
[[ -d "$HOME/.codebuddy/commands" ]] && PLATFORM_TARGETS+=("codebuddy-cli|$HOME/.codebuddy/commands")
[[ -d "$HOME/.workbuddy/skills" ]] && PLATFORM_TARGETS+=("workbuddy|$HOME/.workbuddy/skills")
[[ -d "$HOME/.workbuddy/commands" ]] && PLATFORM_TARGETS+=("workbuddy-cli|$HOME/.workbuddy/commands")

if [[ ${#ARCHIVED[@]} -eq 0 ]]; then
  echo -e "${GREEN}✓${NC} archived_skills 为空，无需清理"
  exit 0
fi

# ── 执行清理 ──
echo -e "${CYAN}Prism Clean${NC}"
if $DRY_RUN; then
  echo -e "${DIM}模式: 预览（不实际删除）${NC}"
fi
echo "─────────────────────────────────"
echo -e "归档技能: ${YELLOW}${ARCHIVED[*]}${NC}"
echo ""

REMOVED=0
SKIPPED=0

for skill_name in "${ARCHIVED[@]}"; do
  echo -e "  ${CYAN}${skill_name}${NC}"
  found_any=false

  for target in "${PLATFORM_TARGETS[@]}"; do
    platform="${target%%|*}"
    root_dir="${target#*|}"
    link_path="${root_dir}/${skill_name}"

    if [[ -L "$link_path" ]]; then
      found_any=true
      link_dest=$(readlink "$link_path")
      if $DRY_RUN; then
        echo -e "    ${YELLOW}⌫${NC} ${platform}: 将删除 ${DIM}→ ${link_dest}${NC}"
      else
        rm "$link_path"
        echo -e "    ${YELLOW}⌫${NC} ${platform}: 已删除 ${DIM}→ ${link_dest}${NC}"
      fi
      ((REMOVED++)) || true
    else
      ((SKIPPED++)) || true
    fi
  done

  if ! $found_any; then
    echo -e "    ${DIM}(各平台均无链接)${NC}"
  fi
done

echo ""
echo "─────────────────────────────────"
if $DRY_RUN; then
  echo -e "  预览: ${YELLOW}${REMOVED} 个链接待删除${NC}，${DIM}${SKIPPED} 个已不存在${NC}"
  echo -e "  ${DIM}确认后去掉 --dry-run 执行${NC}"
else
  echo -e "  已清理: ${GREEN}${REMOVED} 个链接${NC}，${DIM}${SKIPPED} 个已不存在${NC}"
fi
