#!/usr/bin/env bash
# Prism — workflow 统一 CLI 入口，转发到 shared/scripts/prism_cli.py。
#
# 用法:
#   prism <verb> [args...]       运行指定子命令
#   prism --help                 列出所有子命令
#   prism --version              打印版本（联动 SDK VERSION 文件）
#
# 全局选项:
#   --version, -V                显示版本后退出
#   --json                       以 outer schema 输出 JSON（见 docs/cli-json-schema.json）
#                                当前覆盖: sniff / validate / manifest
#
# 可用子命令:
#   sniff           嗅探项目环境（topic affinity / next_review_number）
#   validate        校验产物格式（frontmatter / 命名规范）
#   validate-trace  扫描痕迹义务家族（task_probe/decision_artifact/...）
#   archive         归档 topic 到 archive/
#   migrate         迁移子目录评审格式
#   sync            嗅探 Prism 三仓 Git 状态
#   finalize        Decision 后一键 tidy + validate + validate-trace (Step 2.5) + scope 提示
#   tidy            工件机械对齐（README/review.index/frontmatter）
#   status          Workspace 活跃 topic 健康度扫描
#   digest          Topic 工件采集（供 Agent 生成摘要）
#   manifest        导出 verb 元数据（stability + schema_compliant）
#
# 退出码: 透传子命令的退出码
#
# 注：本脚本是 prism_cli.py 的 bash 壳，核心实现在：
#   $PRISM_SDK/skills/workflow/shared/scripts/prism_cli.py

set -o pipefail

# 跟随 symlink 解析真实路径（macOS BSD readlink 不支持 -f，手动 loop）
_resolve() {
  local target="$1"
  while [ -L "$target" ]; do
    local link
    link="$(readlink "$target")"
    case "$link" in
      /*) target="$link" ;;
      *)  target="$(cd "$(dirname "$target")" && pwd)/$link" ;;
    esac
  done
  echo "$target"
}

REAL_SCRIPT="$(_resolve "$0")"
SCRIPT_DIR="$(cd "$(dirname "$REAL_SCRIPT")" && pwd)"
PRISM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CLI_SCRIPT="$PRISM_DIR/skills/workflow/shared/scripts/prism_cli.py"

RED='\033[0;31m'
YELLOW='\033[0;33m'
DIM='\033[2m'
NC='\033[0m'

# Python runner 与 bin/setup / bin/doctor 一致：优先 uv run python，缺 uv 时
# 用 python3 fallback 保证 bin/prism 在缺 uv 但已有 python3 的环境（CI / dev
# container / 离线机器）仍能启动 + 自我修复。`uv` 仍是 core contract 硬依赖；
# fallback 模式会向 stderr 输出明确提示，引导跑 bin/setup 安装 uv。
_run_python() {
  if command -v uv >/dev/null 2>&1; then
    exec uv run python "$@"
  fi
  if command -v python3 >/dev/null 2>&1; then
    if [[ "${PRISM_FALLBACK_QUIET:-0}" != "1" ]]; then
      echo -e "${YELLOW}⚠ uv 未安装，bin/prism 使用 python3 fallback 启动（degraded mode）${NC}" >&2
      echo -e "  ${DIM}请运行 $PRISM_DIR/bin/setup 自动安装 uv 以恢复 core contract 一致性${NC}" >&2
    fi
    exec python3 "$@"
  fi
  echo -e "${RED}✗ 未找到 uv 或 python3，无法启动 bin/prism${NC}" >&2
  echo -e "  ${DIM}先安装 Python 3 (https://python.org) 再运行 bin/setup 完成 uv 安装${NC}" >&2
  exit 127
}

# ── --help/-h: 从文件头注释提取 ─────────
if [[ "$1" == "--help" || "$1" == "-h" || -z "$1" ]]; then
  awk 'NR==1 { next } /^$/ { exit } { sub(/^# ?/, ""); print }' "$0"
  # 无参数时附加可用性检查（用户自检入口）
  if [[ -z "$1" ]]; then
    echo ""
    echo "未指定子命令。运行 'prism --help' 查看完整用法。"
    exit 1
  fi
  exit 0
fi

# ── --version ───────────────────────────
if [[ "$1" == "--version" || "$1" == "-V" ]]; then
  _run_python "$CLI_SCRIPT" --version
fi

# ── 前置检查：CLI 脚本必须存在 ──────────
if [[ ! -f "$CLI_SCRIPT" ]]; then
  echo -e "${RED}✗ prism_cli.py 未找到${NC}" >&2
  echo -e "  ${DIM}期望路径: $CLI_SCRIPT${NC}" >&2
  echo -e "  ${DIM}运行 bin/doctor --scope cli 诊断${NC}" >&2
  exit 127
fi

# ── 转发到 Python 实现 ──────────────────
_run_python "$CLI_SCRIPT" "$@"
