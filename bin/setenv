#!/usr/bin/env bash
# Prism setenv — 初始化/读取 prism.local.yaml，输出可 source 的环境变量。
#
# 用法:
#   bin/setenv              显示当前配置
#   bin/setenv --init       交互式创建 prism.local.yaml
#   bin/setenv --init --non-interactive  非交互创建（从参数/环境变量读取）
#   bin/setenv --export     输出 export 语句（可 source）
#   bin/setenv --validate   校验 prism.local.yaml 路径是否有效
#   source <(bin/setenv --export)   注入环境变量到当前 shell
#
# --non-interactive 环境变量：
#   PRISM_SDK_PATH     SDK 路径（默认当前 Prism 目录）
#   PRISM_SKILLS_PATH  Skills 路径（默认 ~/prism-skills）
#   PRISM_VAULT_PATH   Vault 路径（默认 iCloud AI Obsidian）
#   PRISM_WS_SUBDIR    Workspace 子目录（默认 Prism/Workspace）

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PRISM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG="$PRISM_DIR/prism.local.yaml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

yaml_get() {
  local key="$1"
  grep "^${key}:" "$CONFIG" 2>/dev/null | sed "s/^${key}: *//"
}

show_config() {
  if [[ ! -f "$CONFIG" ]]; then
    echo -e "${RED}✗ prism.local.yaml 不存在，运行 bin/setenv --init 初始化${NC}"
    exit 1
  fi

  local sdk skills vault ws_sub
  sdk=$(yaml_get sdk_path)
  skills=$(yaml_get skills_path)
  vault=$(yaml_get vault_path)
  ws_sub=$(yaml_get workspace_subdir)

  echo -e "${CYAN}Prism Local Configuration${NC}"
  echo "─────────────────────────────────"
  echo -e "  SDK 路径:       ${GREEN}${sdk}${NC}"
  echo -e "  Skills 路径:    ${GREEN}${skills}${NC}"
  echo -e "  Vault 路径:     ${GREEN}${vault}${NC}"
  echo -e "  Workspace 子目录: ${ws_sub}"
  echo ""
  echo -e "  ${CYAN}完整路径:${NC}"
  echo -e "    Workspace: ${vault}/${ws_sub}"
  echo -e "    Skills:    ${skills}"
  echo ""

  echo -e "  ${CYAN}注册项目:${NC}"
  local in_projects=false
  while IFS= read -r line; do
    if [[ "$line" == "projects:" ]]; then
      in_projects=true
      continue
    fi
    if $in_projects; then
      if [[ "$line" =~ ^[[:space:]]+([A-Za-z0-9_-]+):[[:space:]]*(.*) ]]; then
        local code="${BASH_REMATCH[1]}"
        local path="${BASH_REMATCH[2]}"
        echo -e "    ${code}: ${path}"
      elif [[ ! "$line" =~ ^[[:space:]] ]]; then
        break
      fi
    fi
  done < "$CONFIG"

  echo ""
  echo -e "  ${CYAN}路径状态:${NC}"
  [[ -d "$sdk" ]] && echo -e "    SDK:       ${GREEN}✓${NC}" || echo -e "    SDK:       ${RED}✗ 不存在${NC}"
  [[ -d "$skills" ]] && echo -e "    Skills:    ${GREEN}✓${NC}" || echo -e "    Skills:    ${RED}✗ 不存在${NC}"
  [[ -d "$vault" ]] && echo -e "    Vault:     ${GREEN}✓${NC}" || echo -e "    Vault:     ${RED}✗ 不存在${NC}"
  [[ -d "${vault}/${ws_sub}" ]] && echo -e "    Workspace: ${GREEN}✓${NC}" || echo -e "    Workspace: ${YELLOW}⚠ 不存在${NC}"
}

do_export() {
  if [[ ! -f "$CONFIG" ]]; then
    echo "# prism.local.yaml not found" >&2
    exit 1
  fi

  local sdk skills vault ws_sub
  sdk=$(yaml_get sdk_path)
  skills=$(yaml_get skills_path)
  vault=$(yaml_get vault_path)
  ws_sub=$(yaml_get workspace_subdir)

  echo "export PRISM_DIR=\"${sdk}\""
  echo "export PRISM_SKILLS=\"${skills}\""
  echo "export PRISM_VAULT=\"${vault}\""
  echo "export PRISM_WORKSPACE=\"${vault}/${ws_sub}\""
}

do_validate() {
  if [[ ! -f "$CONFIG" ]]; then
    echo -e "${RED}✗ prism.local.yaml 不存在${NC}"
    exit 1
  fi

  echo -e "${CYAN}Prism 配置校验${NC}"
  echo "─────────────────────────────────"

  local errors=0
  local required_keys=("sdk_path" "skills_path" "vault_path" "workspace_subdir")

  for key in "${required_keys[@]}"; do
    local val
    val=$(yaml_get "$key")
    if [[ -z "$val" ]]; then
      echo -e "  ${RED}✗${NC} ${key}: 缺失（必填字段）"
      ((errors++)) || true
    else
      echo -e "  ${GREEN}✓${NC} ${key}: ${val}"
    fi
  done

  echo ""
  echo -e "  ${CYAN}路径可达性:${NC}"

  local sdk skills vault ws_sub
  sdk=$(yaml_get sdk_path)
  skills=$(yaml_get skills_path)
  vault=$(yaml_get vault_path)
  ws_sub=$(yaml_get workspace_subdir)

  for pair in "SDK:${sdk}" "Skills:${skills}" "Vault:${vault}"; do
    local label="${pair%%:*}"
    local p="${pair#*:}"
    if [[ -z "$p" ]]; then
      continue
    elif [[ -d "$p" ]]; then
      echo -e "  ${GREEN}✓${NC} ${label}: 可达"
    else
      echo -e "  ${RED}✗${NC} ${label}: 不可达 ${p}"
      ((errors++)) || true
    fi
  done

  if [[ -n "$vault" && -n "$ws_sub" ]]; then
    local ws="${vault}/${ws_sub}"
    if [[ -d "$ws" ]]; then
      echo -e "  ${GREEN}✓${NC} Workspace: 可达"
    else
      echo -e "  ${YELLOW}⚠${NC} Workspace: 不存在（首次 relink 时自动创建）"
    fi
  fi

  # projects 段检查
  echo ""
  echo -e "  ${CYAN}注册项目:${NC}"
  local proj_count=0
  local in_projects=false
  while IFS= read -r line; do
    if [[ "$line" == "projects:" ]]; then
      in_projects=true
      continue
    fi
    if $in_projects; then
      if [[ "$line" =~ ^[[:space:]]+([A-Za-z0-9_-]+):[[:space:]]*(.*) ]]; then
        local code="${BASH_REMATCH[1]}"
        local p="${BASH_REMATCH[2]}"
        ((proj_count++)) || true
        if [[ -d "$p" ]]; then
          echo -e "    ${GREEN}✓${NC} ${code}: ${p}"
        else
          echo -e "    ${RED}✗${NC} ${code}: 不可达 ${p}"
          ((errors++)) || true
        fi
      elif [[ ! "$line" =~ ^[[:space:]] ]]; then
        break
      fi
    fi
  done < "$CONFIG"

  if [[ $proj_count -eq 0 ]]; then
    echo -e "    ${YELLOW}⚠${NC} 无注册项目"
  fi

  echo ""
  echo "─────────────────────────────────"
  if [[ $errors -gt 0 ]]; then
    echo -e "  ${RED}校验失败：${errors} 个问题${NC}"
    exit 1
  else
    echo -e "  ${GREEN}✓ 校验通过${NC}"
  fi
}

write_config() {
  local sdk="$1" skills="$2" vault="$3" ws_sub="$4"
  cat > "$CONFIG" << 'YAML_END'
# Prism Local Configuration
# 本地路径状态，不入版本控制（受控最小 schema，不可自由扩展）。
# 由 bin/setenv 初始化，bin/relink 读取刷新软链接。

YAML_END
  cat >> "$CONFIG" << CONFDATA
# SDK 路径（Prism 仓库位置）
sdk_path: ${sdk}

# Skills 路径（独立 Git 仓库）
skills_path: ${skills}

# Vault 基础路径（iCloud Obsidian vault，仅承载 Workspace）
vault_path: ${vault}

# Vault 内子目录（相对于 vault_path）
workspace_subdir: ${ws_sub}

# 注册项目（CODE: 本地路径）
# relink 据此刷新 workspace.{code}.local 软链接
projects:
CONFDATA
}

do_init() {
  if [[ -f "$CONFIG" ]]; then
    if $NON_INTERACTIVE; then
      echo -e "${RED}✗ prism.local.yaml 已存在，非交互模式拒绝覆盖。${NC}" >&2
      echo -e "${DIM}如需重新初始化，请先手动删除或备份。${NC}" >&2
      exit 1
    fi
    echo -e "${YELLOW}⚠ prism.local.yaml 已存在${NC}"
    echo ""
    read -r -p "覆盖现有配置？已注册的 projects 段将丢失 [y/N]: " confirm
    if [[ "${confirm,,}" != "y" ]]; then
      echo "已取消。"
      exit 0
    fi
    cp "$CONFIG" "${CONFIG}.bak.$(date +%Y%m%d%H%M%S)"
    echo -e "${DIM}已备份至 ${CONFIG}.bak.*${NC}"
    echo ""
  fi

  echo -e "${CYAN}Prism 配置初始化${NC}"
  echo "─────────────────────────────────"

  local sdk skills vault ws_sub

  if $NON_INTERACTIVE; then
    sdk="${PRISM_SDK_PATH:-$PRISM_DIR}"
    skills="${PRISM_SKILLS_PATH:-$HOME/prism-skills}"
    vault="${PRISM_VAULT_PATH:-$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/AI Obsidian}"
    ws_sub="${PRISM_WS_SUBDIR:-Prism/Workspace}"

    echo -e "  SDK:       ${sdk}"
    echo -e "  Skills:    ${skills}"
    echo -e "  Vault:     ${vault}"
    echo -e "  子目录:    ${ws_sub}"

    write_config "$sdk" "$skills" "$vault" "$ws_sub"
    echo ""
    echo -e "${GREEN}✓ 已创建 prism.local.yaml（非交互模式）${NC}"
    echo -e "运行 ${CYAN}bin/setenv --validate${NC} 校验路径，${CYAN}bin/relink${NC} 刷新软链接。"
    return
  fi

  read -r -p "SDK 路径 [${PRISM_DIR}]: " sdk
  sdk="${sdk:-$PRISM_DIR}"

  local default_skills="$HOME/prism-skills"
  read -r -p "Skills 路径 [${default_skills}]: " skills
  skills="${skills:-$default_skills}"

  local default_vault="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/AI Obsidian"
  read -r -p "Vault 路径 [${default_vault}]: " vault
  vault="${vault:-$default_vault}"

  read -r -p "Workspace 子目录 [Prism/Workspace]: " ws_sub
  ws_sub="${ws_sub:-Prism/Workspace}"

  write_config "$sdk" "$skills" "$vault" "$ws_sub"

  echo ""
  echo -e "${GREEN}✓ 已创建 prism.local.yaml${NC}"
  echo ""

  local add_more="y"
  while [[ "$add_more" == "y" ]]; do
    local code path
    read -r -p "注册项目代号 (留空跳过): " code
    [[ -z "$code" ]] && break
    read -r -p "  本地路径: " path
    echo "  ${code}: ${path}" >> "$CONFIG"
    echo -e "  ${GREEN}✓ 已注册 ${code}${NC}"
    read -r -p "继续注册? [y/N]: " add_more
    add_more="${add_more:-n}"
  done

  echo ""
  echo -e "${GREEN}配置完成。运行 bin/relink 刷新软链接。${NC}"
}

NON_INTERACTIVE=false
ACTION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --init)             ACTION="init"; shift ;;
    --export)           ACTION="export"; shift ;;
    --validate)         ACTION="validate"; shift ;;
    --non-interactive)  NON_INTERACTIVE=true; shift ;;
    --help|-h)
      echo "用法: bin/setenv [--init [--non-interactive]|--export|--validate|--help]"
      echo "  (无参数)          显示当前配置"
      echo "  --init            交互式创建 prism.local.yaml"
      echo "  --init --non-interactive  从环境变量读取路径创建配置"
      echo "  --export          输出 export 语句（配合 source 使用）"
      echo "  --validate        校验 prism.local.yaml 字段与路径"
      exit 0
      ;;
    *) echo "未知参数: $1"; exit 1 ;;
  esac
done

case "${ACTION:-show}" in
  init)     do_init ;;
  export)   do_export ;;
  validate) do_validate ;;
  show)     show_config ;;
esac
