#!/usr/bin/env bash
# Prism setenv — 初始化/读取 prism.local.yaml，输出可 source 的环境变量。
#
# 用法:
#   bin/setenv              显示当前配置
#   bin/setenv --init       交互式创建 prism.local.yaml
#   bin/setenv --init --non-interactive  非交互创建（从参数/环境变量读取）
#   bin/setenv --export     输出 export 语句（可 source）
#   bin/setenv --validate   校验 prism.local.yaml 路径是否有效
#   bin/setenv --sync       从 Workspace project.yaml 同步项目注册
#   source <(bin/setenv --export)   注入环境变量到当前 shell
#
# --non-interactive 环境变量：
#   PRISM_SDK_PATH     SDK 路径（默认当前 Prism 目录）
#   PRISM_SKILLS_PATH  Skills 路径（默认 ~/prism-skills）
#   PRISM_VAULT_PATH   Vault 路径（默认 iCloud AI Obsidian）
#   PRISM_WS_SUBDIR    Workspace 子目录（默认 Prism/Workspace）

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PRISM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG="$PRISM_DIR/prism.local.yaml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

yaml_get() {
  local key="$1"
  grep "^${key}:" "$CONFIG" 2>/dev/null | sed "s/^${key}: *//"
}

show_config() {
  if [[ ! -f "$CONFIG" ]]; then
    echo -e "${RED}✗ prism.local.yaml 不存在，运行 bin/setenv --init 初始化${NC}"
    exit 1
  fi

  local sdk skills vault ws_sub
  sdk=$(yaml_get sdk_path)
  skills=$(yaml_get skills_path)
  vault=$(yaml_get vault_path)
  ws_sub=$(yaml_get workspace_subdir)

  local device_id
  device_id=$(yaml_get device_id)

  echo -e "${CYAN}Prism Local Configuration${NC}"
  echo "─────────────────────────────────"
  if [[ -n "$device_id" ]]; then
    echo -e "  设备 ID:       ${GREEN}${device_id}${NC}"
  else
    echo -e "  设备 ID:       ${YELLOW}未设置（运行 bin/setenv --sync 补充）${NC}"
  fi
  echo -e "  SDK 路径:       ${GREEN}${sdk}${NC}"
  echo -e "  Skills 路径:    ${GREEN}${skills}${NC}"
  echo -e "  Vault 路径:     ${GREEN}${vault}${NC}"
  echo -e "  Workspace 子目录: ${ws_sub}"
  echo ""

  local env_p
  env_p=$(yaml_get env_path)
  if [[ -n "$env_p" ]]; then
    echo -e "  Env 层路径:     ${GREEN}${env_p}${NC}"
  else
    echo -e "  Env 层路径:     ${DIM}(未配置，可选)${NC}"
  fi
  echo ""
  echo -e "  ${CYAN}完整路径:${NC}"
  echo -e "    Workspace: ${vault}/${ws_sub}"
  echo -e "    Skills:    ${skills}"
  if [[ -n "$env_p" ]]; then
    echo -e "    Env:       ${env_p}"
  fi
  echo ""

  echo -e "  ${CYAN}注册项目:${NC}"
  local in_projects=false
  while IFS= read -r line; do
    if [[ "$line" == "projects:" ]]; then
      in_projects=true
      continue
    fi
    if $in_projects; then
      if [[ "$line" =~ ^[[:space:]]+([A-Za-z0-9_-]+):[[:space:]]*(.*) ]]; then
        local code="${BASH_REMATCH[1]}"
        local path="${BASH_REMATCH[2]}"
        echo -e "    ${code}: ${path}"
      elif [[ ! "$line" =~ ^[[:space:]] ]]; then
        break
      fi
    fi
  done < "$CONFIG"

  echo ""
  echo -e "  ${CYAN}路径状态:${NC}"
  [[ -d "$sdk" ]] && echo -e "    SDK:       ${GREEN}✓${NC}" || echo -e "    SDK:       ${RED}✗ 不存在${NC}"
  [[ -d "$skills" ]] && echo -e "    Skills:    ${GREEN}✓${NC}" || echo -e "    Skills:    ${RED}✗ 不存在${NC}"
  [[ -d "$vault" ]] && echo -e "    Vault:     ${GREEN}✓${NC}" || echo -e "    Vault:     ${RED}✗ 不存在${NC}"
  [[ -d "${vault}/${ws_sub}" ]] && echo -e "    Workspace: ${GREEN}✓${NC}" || echo -e "    Workspace: ${YELLOW}⚠ 不存在${NC}"
  if [[ -n "$env_p" ]]; then
    [[ -d "$env_p" ]] && echo -e "    Env:       ${GREEN}✓${NC}" || echo -e "    Env:       ${YELLOW}⚠ 不存在${NC}"
  fi
}

do_export() {
  if [[ ! -f "$CONFIG" ]]; then
    echo "# prism.local.yaml not found" >&2
    exit 1
  fi

  local sdk skills vault ws_sub
  sdk=$(yaml_get sdk_path)
  skills=$(yaml_get skills_path)
  vault=$(yaml_get vault_path)
  ws_sub=$(yaml_get workspace_subdir)

  local device_id
  device_id=$(yaml_get device_id)

  echo "export PRISM_DEVICE_ID=\"${device_id}\""
  echo "export PRISM_DIR=\"${sdk}\""
  echo "export PRISM_SKILLS=\"${skills}\""
  echo "export PRISM_VAULT=\"${vault}\""
  echo "export PRISM_WORKSPACE=\"${vault}/${ws_sub}\""

  local env_p
  env_p=$(yaml_get env_path)
  if [[ -n "$env_p" ]]; then
    echo "export PRISM_ENV_PATH=\"${env_p}\""
  fi
}

do_validate() {
  if [[ ! -f "$CONFIG" ]]; then
    echo -e "${RED}✗ prism.local.yaml 不存在${NC}"
    exit 1
  fi

  echo -e "${CYAN}Prism 配置校验${NC}"
  echo "─────────────────────────────────"

  local errors=0

  # device_id 单独检查（非路径类型）
  local did
  did=$(yaml_get device_id)
  if [[ -z "$did" ]]; then
    echo -e "  ${YELLOW}⚠${NC} device_id: 缺失（运行 bin/setenv --sync 自动补充）"
  else
    echo -e "  ${GREEN}✓${NC} device_id: ${did}"
  fi

  local required_keys=("sdk_path" "skills_path" "vault_path" "workspace_subdir")

  for key in "${required_keys[@]}"; do
    local val
    val=$(yaml_get "$key")
    if [[ -z "$val" ]]; then
      echo -e "  ${RED}✗${NC} ${key}: 缺失（必填字段）"
      ((errors++)) || true
    else
      echo -e "  ${GREEN}✓${NC} ${key}: ${val}"
    fi
  done

  # env_path 可选字段检查
  local env_p
  env_p=$(yaml_get env_path)
  if [[ -n "$env_p" ]]; then
    echo -e "  ${GREEN}✓${NC} env_path: ${env_p}"
  else
    echo -e "  ${DIM}⊘${NC} env_path: 未配置（可选）"
  fi

  echo ""
  echo -e "  ${CYAN}路径可达性:${NC}"

  local sdk skills vault ws_sub
  sdk=$(yaml_get sdk_path)
  skills=$(yaml_get skills_path)
  vault=$(yaml_get vault_path)
  ws_sub=$(yaml_get workspace_subdir)

  for pair in "SDK:${sdk}" "Skills:${skills}" "Vault:${vault}"; do
    local label="${pair%%:*}"
    local p="${pair#*:}"
    if [[ -z "$p" ]]; then
      continue
    elif [[ -d "$p" ]]; then
      echo -e "  ${GREEN}✓${NC} ${label}: 可达"
    else
      echo -e "  ${RED}✗${NC} ${label}: 不可达 ${p}"
      ((errors++)) || true
    fi
  done

  if [[ -n "$env_p" ]]; then
    if [[ -d "$env_p" ]]; then
      echo -e "  ${GREEN}✓${NC} Env: 可达"
    else
      echo -e "  ${YELLOW}⚠${NC} Env: 不可达 ${env_p}（可选，不阻塞）"
    fi
  fi

  if [[ -n "$vault" && -n "$ws_sub" ]]; then
    local ws="${vault}/${ws_sub}"
    if [[ -d "$ws" ]]; then
      echo -e "  ${GREEN}✓${NC} Workspace: 可达"
    else
      echo -e "  ${YELLOW}⚠${NC} Workspace: 不存在（首次 relink 时自动创建）"
    fi
  fi

  # projects 段检查
  echo ""
  echo -e "  ${CYAN}注册项目:${NC}"
  local proj_count=0
  local in_projects=false
  while IFS= read -r line; do
    if [[ "$line" == "projects:" ]]; then
      in_projects=true
      continue
    fi
    if $in_projects; then
      if [[ "$line" =~ ^[[:space:]]+([A-Za-z0-9_-]+):[[:space:]]*(.*) ]]; then
        local code="${BASH_REMATCH[1]}"
        local p="${BASH_REMATCH[2]}"
        ((proj_count++)) || true
        if [[ -d "$p" ]]; then
          echo -e "    ${GREEN}✓${NC} ${code}: ${p}"
        else
          echo -e "    ${RED}✗${NC} ${code}: 不可达 ${p}"
          ((errors++)) || true
        fi
      elif [[ ! "$line" =~ ^[[:space:]] ]]; then
        break
      fi
    fi
  done < "$CONFIG"

  if [[ $proj_count -eq 0 ]]; then
    echo -e "    ${YELLOW}⚠${NC} 无注册项目"
  fi

  echo ""
  echo "─────────────────────────────────"
  if [[ $errors -gt 0 ]]; then
    echo -e "  ${RED}校验失败：${errors} 个问题${NC}"
    exit 1
  else
    echo -e "  ${GREEN}✓ 校验通过${NC}"
  fi
}

write_config() {
  local sdk="$1" skills="$2" vault="$3" ws_sub="$4" env_p="${5:-}"
  local device_id
  device_id=$(hostname -s)
  cat > "$CONFIG" << 'YAML_END'
# Prism Local Configuration
# 本地路径状态，不入版本控制（受控最小 schema，不可自由扩展）。
# 由 bin/setenv 初始化，bin/relink 读取刷新软链接。

YAML_END
  cat >> "$CONFIG" << CONFDATA
# 设备标识（hostname -s 自动生成，跨设备路径解析用）
device_id: ${device_id}

# SDK 路径（Prism 仓库位置）
sdk_path: ${sdk}

# Skills 路径（独立 Git 仓库）
skills_path: ${skills}

# Vault 基础路径（iCloud Obsidian vault，仅承载 Workspace）
vault_path: ${vault}

# Vault 内子目录（相对于 vault_path）
workspace_subdir: ${ws_sub}

CONFDATA
  if [[ -n "$env_p" ]]; then
    cat >> "$CONFIG" << CONFDATA
# 可选：env 层路径（如 ArnoDotFiles），存在则分发其 skills/ 下的技能
env_path: ${env_p}

CONFDATA
  fi
  cat >> "$CONFIG" << 'CONFDATA'
# 注册项目（CODE: 本地路径）
# relink 据此刷新 workspace.{code}.local 软链接
projects:
CONFDATA
}

do_init() {
  if [[ -f "$CONFIG" ]]; then
    if $NON_INTERACTIVE; then
      echo -e "${RED}✗ prism.local.yaml 已存在，非交互模式拒绝覆盖。${NC}" >&2
      echo -e "${DIM}如需重新初始化，请先手动删除或备份。${NC}" >&2
      exit 1
    fi
    echo -e "${YELLOW}⚠ prism.local.yaml 已存在${NC}"
    echo ""
    read -r -p "覆盖现有配置？已注册的 projects 段将丢失 [y/N]: " confirm
    if [[ "${confirm,,}" != "y" ]]; then
      echo "已取消。"
      exit 0
    fi
    cp "$CONFIG" "${CONFIG}.bak.$(date +%Y%m%d%H%M%S)"
    echo -e "${DIM}已备份至 ${CONFIG}.bak.*${NC}"
    echo ""
  fi

  echo -e "${CYAN}Prism 配置初始化${NC}"
  echo "─────────────────────────────────"

  local sdk skills vault ws_sub env_p

  if $NON_INTERACTIVE; then
    sdk="${PRISM_SDK_PATH:-$PRISM_DIR}"
    skills="${PRISM_SKILLS_PATH:-$HOME/prism-skills}"
    vault="${PRISM_VAULT_PATH:-$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/AI Obsidian}"
    ws_sub="${PRISM_WS_SUBDIR:-Prism/Workspace}"
    env_p="${PRISM_ENV_PATH:-}"

    echo -e "  SDK:       ${sdk}"
    echo -e "  Skills:    ${skills}"
    echo -e "  Vault:     ${vault}"
    echo -e "  子目录:    ${ws_sub}"
    [[ -n "$env_p" ]] && echo -e "  Env:       ${env_p}"

    write_config "$sdk" "$skills" "$vault" "$ws_sub" "$env_p"
    echo ""
    echo -e "${GREEN}✓ 已创建 prism.local.yaml（非交互模式）${NC}"
    echo -e "运行 ${CYAN}bin/setenv --validate${NC} 校验路径，${CYAN}bin/relink${NC} 刷新软链接。"
    return
  fi

  read -r -p "SDK 路径 [${PRISM_DIR}]: " sdk
  sdk="${sdk:-$PRISM_DIR}"

  local default_skills="$HOME/prism-skills"
  read -r -p "Skills 路径 [${default_skills}]: " skills
  skills="${skills:-$default_skills}"

  local default_vault="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/AI Obsidian"
  read -r -p "Vault 路径 [${default_vault}]: " vault
  vault="${vault:-$default_vault}"

  read -r -p "Workspace 子目录 [Prism/Workspace]: " ws_sub
  ws_sub="${ws_sub:-Prism/Workspace}"

  echo ""
  echo -e "${DIM}可选：Env 层路径（如 ArnoDotFiles dotfiles 仓库），留空跳过${NC}"
  read -r -p "Env 层路径 []: " env_p
  env_p="${env_p:-}"

  write_config "$sdk" "$skills" "$vault" "$ws_sub" "$env_p"

  echo ""
  echo -e "${GREEN}✓ 已创建 prism.local.yaml${NC}"
  echo ""

  local add_more="y"
  while [[ "$add_more" == "y" ]]; do
    local code path
    read -r -p "注册项目代号 (留空跳过): " code
    [[ -z "$code" ]] && break
    read -r -p "  本地路径: " path
    echo "  ${code}: ${path}" >> "$CONFIG"
    echo -e "  ${GREEN}✓ 已注册 ${code}${NC}"
    read -r -p "继续注册? [y/N]: " add_more
    add_more="${add_more:-n}"
  done

  echo ""
  echo -e "${GREEN}配置完成。运行 bin/relink 刷新软链接。${NC}"
}

do_sync() {
  if [[ ! -f "$CONFIG" ]]; then
    echo -e "${RED}✗ prism.local.yaml 不存在，先运行 bin/setenv --init${NC}"
    exit 1
  fi

  local device_id vault ws_sub ws_root
  device_id=$(yaml_get device_id)
  vault=$(yaml_get vault_path)
  ws_sub=$(yaml_get workspace_subdir)
  ws_root="${vault}/${ws_sub}"

  # 如果没有 device_id，自动补充
  if [[ -z "$device_id" ]]; then
    device_id=$(hostname -s)
    # 插入 device_id 到 sdk_path 之前
    local tmp="${CONFIG}.tmp.$$"
    awk -v did="$device_id" '
      /^sdk_path:/ && !inserted {
        print "# 设备标识（hostname -s 自动生成，跨设备路径解析用）"
        print "device_id: " did
        print ""
        inserted=1
      }
      { print }
    ' "$CONFIG" > "$tmp" && mv "$tmp" "$CONFIG"
    echo -e "${GREEN}⟳${NC} 自动补充 device_id: ${device_id}"
  fi

  echo -e "${CYAN}Prism Sync — 从 Workspace 同步项目注册${NC}"
  echo -e "${DIM}设备: ${device_id}${NC}"
  echo "─────────────────────────────────"

  if [[ ! -d "$ws_root" ]]; then
    echo -e "${RED}✗ Workspace 根目录不存在: ${ws_root}${NC}"
    exit 1
  fi

  # 收集本地已注册项目（bash 3.2 兼容，用 \n 分隔的 CODE=PATH 列表）
  local local_project_list=""
  local in_projects=false
  while IFS= read -r line; do
    if [[ "$line" == "projects:" ]]; then
      in_projects=true
      continue
    fi
    if $in_projects; then
      if [[ "$line" =~ ^[[:space:]]+([A-Za-z0-9_-]+):[[:space:]]*(.*) ]]; then
        local_project_list="${local_project_list}${BASH_REMATCH[1]}=${BASH_REMATCH[2]}"$'\n'
      elif [[ ! "$line" =~ ^[[:space:]] ]]; then
        break
      fi
    fi
  done < "$CONFIG"

  local added=0
  local updated=0
  local skipped=0

  # 扫描 Workspace 内所有 project.yaml
  for proj_dir in "$ws_root"/*/; do
    [[ -d "$proj_dir" ]] || continue
    local proj_yaml="${proj_dir}project.yaml"
    [[ -f "$proj_yaml" ]] || continue

    local code
    code=$(grep "^code:" "$proj_yaml" 2>/dev/null | sed 's/^code: *//; s/^"//; s/"$//')
    [[ -z "$code" ]] && continue

    echo -e "\n  ${CYAN}${code}${NC}"

    # 解析 paths（支持 map 和 list 两种格式）
    local resolved_path=""
    local paths_is_map=false
    local in_paths=false
    local paths_raw=""

    while IFS= read -r line; do
      if [[ "$line" =~ ^paths: ]]; then
        in_paths=true
        continue
      fi
      if $in_paths; then
        if [[ "$line" =~ ^[[:space:]]+-[[:space:]]*(.*) ]]; then
          paths_raw="${paths_raw}list:${BASH_REMATCH[1]}"$'\n'
        elif [[ "$line" =~ ^[[:space:]]+([A-Za-z0-9_-]+):[[:space:]]*(.*) ]]; then
          paths_raw="${paths_raw}map:${BASH_REMATCH[1]}:${BASH_REMATCH[2]}"$'\n'
          paths_is_map=true
        elif [[ ! "$line" =~ ^[[:space:]] || "$line" =~ ^[a-z_]+: ]]; then
          break
        fi
      fi
    done < "$proj_yaml"

    # 解析路径
    if $paths_is_map; then
      local match
      match=$(echo "$paths_raw" | grep "^map:${device_id}:" | head -1 || true)
      if [[ -n "$match" ]]; then
        resolved_path="${match#map:${device_id}:}"
        resolved_path=$(echo "$resolved_path" | sed 's/^"//; s/"$//')
      fi
    else
      while IFS= read -r entry; do
        [[ -z "$entry" ]] && continue
        local p="${entry#list:}"
        p=$(echo "$p" | sed 's/^"//; s/"$//')
        local expanded="${p/#\~/$HOME}"
        if [[ -d "$expanded" ]]; then
          resolved_path="$expanded"
          break
        fi
      done <<< "$paths_raw"
    fi

    # 已在本地注册？
    local registered_path=""
    registered_path=$(echo "$local_project_list" | grep "^${code}=" | head -1 | sed "s/^${code}=//" || true)
    if [[ -n "$registered_path" ]]; then
      if [[ -d "$registered_path" ]]; then
        echo -e "    ${GREEN}✓${NC} 已注册: ${registered_path}"

        # 回写 project.yaml（如果是 map 格式且缺少当前设备）
        _sync_writeback_path "$proj_yaml" "$device_id" "$registered_path" "$paths_is_map"
        ((skipped++)) || true
        continue
      else
        echo -e "    ${YELLOW}⚠${NC} 已注册但路径不可达: ${registered_path}"
      fi
    fi

    # 尝试已解析的路径
    if [[ -n "$resolved_path" && -d "$resolved_path" ]]; then
      echo -e "    ${GREEN}⟳${NC} 从 project.yaml 解析: ${resolved_path}"
      _sync_add_project "$code" "$resolved_path"
      _sync_writeback_path "$proj_yaml" "$device_id" "$resolved_path" "$paths_is_map"
      ((added++)) || true
      continue
    fi

    # 尝试 repo 字段做 git remote 匹配
    local repo_url
    repo_url=$(grep "^repo:" "$proj_yaml" 2>/dev/null | sed 's/^repo: *//; s/^"//; s/"$//' || true)
    if [[ -n "$repo_url" ]]; then
      local found_by_repo=""
      found_by_repo=$(_sync_find_by_remote "$repo_url" || true)
      if [[ -n "$found_by_repo" ]]; then
        echo -e "    ${GREEN}⟳${NC} 通过 git remote 匹配: ${found_by_repo}"
        _sync_add_project "$code" "$found_by_repo"
        _sync_writeback_path "$proj_yaml" "$device_id" "$found_by_repo" "$paths_is_map"
        ((added++)) || true
        continue
      fi
    fi

    # 无法自动解析，交互提示
    if $NON_INTERACTIVE; then
      echo -e "    ${YELLOW}⊘${NC} 无法自动解析，跳过（非交互模式）"
      ((skipped++)) || true
      continue
    fi

    echo -e "    ${YELLOW}?${NC} 未找到本地路径"
    read -r -p "    输入 ${code} 的本地路径（留空跳过）: " user_path
    if [[ -n "$user_path" ]]; then
      # 展开 ~
      user_path="${user_path/#\~/$HOME}"
      if [[ -d "$user_path" ]]; then
        _sync_add_project "$code" "$user_path"
        _sync_writeback_path "$proj_yaml" "$device_id" "$user_path" "$paths_is_map"
        ((added++)) || true
      else
        echo -e "    ${RED}✗${NC} 路径不存在: ${user_path}"
        ((skipped++)) || true
      fi
    else
      ((skipped++)) || true
    fi
  done

  echo ""
  echo "─────────────────────────────────"
  echo -e "  新增: ${GREEN}${added}${NC}  跳过: ${DIM}${skipped}${NC}"
  if [[ $added -gt 0 ]]; then
    echo -e "\n  运行 ${CYAN}bin/relink${NC} 刷新软链接。"
  fi
}

_sync_add_project() {
  local code="$1" path="$2"
  echo "  ${code}: ${path}" >> "$CONFIG"
}

_sync_writeback_path() {
  local proj_yaml="$1" device_id="$2" local_path="$3" is_map="$4"
  # 检查 project.yaml 是否已有当前 device_id 的条目
  if grep -q "  ${device_id}:" "$proj_yaml" 2>/dev/null; then
    return 0
  fi

  if [[ "$is_map" == "true" ]]; then
    # map 格式：在 paths 段末尾追加当前设备
    local tmp="${proj_yaml}.tmp.$$"
    awk -v did="$device_id" -v lp="$local_path" '
      /^paths:/ { in_paths=1; print; next }
      in_paths && /^[^ ]/ && !/^  / {
        print "  " did ": " lp
        in_paths=0
      }
      { print }
      END { if (in_paths) print "  " did ": " lp }
    ' "$proj_yaml" > "$tmp" && mv "$tmp" "$proj_yaml"
    echo -e "    ${DIM}↪ 已写回 project.yaml (${device_id})${NC}"
  else
    # list 格式：转换为 map 格式
    local tmp="${proj_yaml}.tmp.$$"
    local converted=false
    awk -v did="$device_id" -v lp="$local_path" '
      /^paths:/ { in_paths=1; print; next }
      in_paths && /^  - / {
        # 跳过旧 list 条目（保留为注释）
        sub(/^  - /, "  # (legacy) ")
        print
        next
      }
      in_paths && /^[^ ]/ && !/^  / {
        if (!wrote) {
          print "  " did ": " lp
          wrote=1
        }
        in_paths=0
      }
      { print }
      END { if (in_paths && !wrote) print "  " did ": " lp }
    ' "$proj_yaml" > "$tmp" && mv "$tmp" "$proj_yaml"
    echo -e "    ${DIM}↪ project.yaml paths 已从 list 转为 map 格式${NC}"
  fi
}

_sync_find_by_remote() {
  local target_remote="$1"
  # 在常见目录搜索匹配的 git remote
  local search_dirs=("$HOME/Desktop" "$HOME/Projects" "$HOME/code" "$HOME/dev" "$HOME/Work" "$HOME/Desktop/Work")
  for dir in "${search_dirs[@]}"; do
    [[ -d "$dir" ]] || continue
    while IFS= read -r git_dir; do
      local repo_dir
      repo_dir=$(dirname "$git_dir")
      local remote
      remote=$(git -C "$repo_dir" remote get-url origin 2>/dev/null)
      if [[ "$remote" == "$target_remote" ]]; then
        echo "$repo_dir"
        return 0
      fi
    done < <(find "$dir" -maxdepth 3 -name ".git" -type d 2>/dev/null)
  done
  return 1
}

NON_INTERACTIVE=false
ACTION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --init)             ACTION="init"; shift ;;
    --export)           ACTION="export"; shift ;;
    --validate)         ACTION="validate"; shift ;;
    --sync)             ACTION="sync"; shift ;;
    --non-interactive)  NON_INTERACTIVE=true; shift ;;
    --help|-h)
      echo "用法: bin/setenv [--init [--non-interactive]|--export|--validate|--sync|--help]"
      echo "  (无参数)          显示当前配置"
      echo "  --init            交互式创建 prism.local.yaml"
      echo "  --init --non-interactive  从环境变量读取路径创建配置"
      echo "  --export          输出 export 语句（配合 source 使用）"
      echo "  --validate        校验 prism.local.yaml 字段与路径"
      echo "  --sync            从 Workspace project.yaml 同步项目注册"
      exit 0
      ;;
    *) echo "未知参数: $1"; exit 1 ;;
  esac
done

case "${ACTION:-show}" in
  init)     do_init ;;
  export)   do_export ;;
  validate) do_validate ;;
  sync)     do_sync ;;
  show)     show_config ;;
esac
