#!/usr/bin/env bash
# Prism relink — 基于 prism.local.yaml 刷新所有软链接。
#
# 用法:
#   bin/relink              刷新所有软链接
#   bin/relink --check      仅检查状态，不修改
#   bin/relink --dry-run    预览变更，不实际执行
#   bin/relink --project X  仅刷新指定项目
#   bin/relink --prune      清理陈旧/失效软链接（可与 --dry-run 组合）

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PRISM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG="$PRISM_DIR/prism.local.yaml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

DRY_RUN=false
CHECK_ONLY=false
PRUNE=false
TARGET_PROJECT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --check)    CHECK_ONLY=true; shift ;;
    --dry-run)  DRY_RUN=true; shift ;;
    --prune)    PRUNE=true; shift ;;
    --project)
      if [[ $# -lt 2 || -z "$2" ]]; then
        echo -e "${RED}✗ --project 需要指定项目代号${NC}" >&2; exit 1
      fi
      TARGET_PROJECT="$2"; shift 2
      ;;
    --help|-h)
      echo "用法: bin/relink [--check|--dry-run|--prune|--project CODE]"
      echo "  (无参数)     刷新所有软链接"
      echo "  --check      仅检查状态"
      echo "  --dry-run    预览变更"
      echo "  --prune      清理陈旧/失效软链接（可与 --dry-run 组合）"
      echo "  --project X  仅刷新指定项目"
      exit 0
      ;;
    *) echo "未知参数: $1"; exit 1 ;;
  esac
done

if [[ ! -f "$CONFIG" ]]; then
  echo -e "${RED}✗ prism.local.yaml 不存在，运行 bin/setenv --init 初始化${NC}"
  exit 1
fi

yaml_get() {
  (grep "^${1}:" "$CONFIG" 2>/dev/null || true) | tail -1 | sed "s/^${1}: *//"
}

_load_default_workspace_from_export() {
  local py="$PRISM_DIR/skills/workflow/shared/scripts/workspace_env_export.py"
  [[ -f "$py" ]] || return 1
  local out vault pwr
  if [[ -x "${PRISM_DIR}/.venv/bin/python3" ]]; then
    out=$("${PRISM_DIR}/.venv/bin/python3" "$py" "$CONFIG" 2>/dev/null) || return 1
  elif command -v uv >/dev/null 2>&1; then
    out=$(uv run python "$py" "$CONFIG" 2>/dev/null) || return 1
  else
    out=$(python3 "$py" "$CONFIG" 2>/dev/null) || return 1
  fi
  vault=$(echo "$out" | sed -n 's/^export PRISM_VAULT="\(.*\)"$/\1/p')
  pwr=$(echo "$out" | sed -n 's/^export PRISM_WORKSPACE="\(.*\)"$/\1/p')
  [[ -n "$vault" ]] && VAULT_PATH="$vault"
  if [[ -n "$pwr" && -n "$vault" ]]; then
    WS_SUBDIR="${pwr#"${vault}/"}"
  fi
}

DEVICE_ID=$(yaml_get device_id)
SDK_PATH=$(yaml_get sdk_path)
SKILLS_PATH=$(yaml_get skills_path)
VAULT_PATH=$(yaml_get workspace_root)
[[ -z "$VAULT_PATH" ]] && VAULT_PATH=$(yaml_get vault_path)
WS_SUBDIR=$(yaml_get workspace_subdir)
ENV_PATH=$(yaml_get env_path)

if [[ -z "$VAULT_PATH" || -z "$WS_SUBDIR" ]]; then
  _load_default_workspace_from_export || true
fi

# ── 必填字段校验（fail-fast）──────────
_missing=""
[[ -z "$DEVICE_ID" ]]  && _missing="$_missing device_id"
[[ -z "$SDK_PATH" ]]   && _missing="$_missing sdk_path"
[[ -z "$VAULT_PATH" ]] && _missing="$_missing workspace_root/vault_path"
[[ -z "$WS_SUBDIR" ]]  && _missing="$_missing workspace_subdir"

if [[ -n "$_missing" ]]; then
  echo -e "${RED}✗ prism.local.yaml 缺少必填字段:${_missing}${NC}" >&2
  echo -e "  请运行 ${CYAN}bin/setenv --init${NC} 补全配置" >&2
  exit 1
fi

# 可选字段警告
if [[ -z "$ENV_PATH" ]]; then
  :  # env_path 可选，静默跳过
elif [[ ! -d "$ENV_PATH" ]]; then
  echo -e "${YELLOW}⚠ env_path 配置但路径不存在: ${ENV_PATH}${NC}" >&2
fi

WS_ROOT="${VAULT_PATH}/${WS_SUBDIR}"

RESOLVER="$SDK_PATH/skills/workflow/shared/scripts/workspace_resolve.py"
_run_resolver_tsv() {
  if [[ ! -f "$RESOLVER" ]]; then
    return 1
  fi
  if command -v uv >/dev/null 2>&1; then
    uv run python "$RESOLVER" --config "$CONFIG" --tsv 2>/dev/null
  else
    python3 "$RESOLVER" --config "$CONFIG" --tsv 2>/dev/null
  fi
}

TOTAL=0
OK=0
FIXED=0
ERRORS=0
SKIPPED_ARCHIVED=0
PLATFORM_TARGETS=()

# 解析 archived_skills 列表
ARCHIVED_SKILLS=()
_in_archived=false
while IFS= read -r line; do
  if [[ "$line" =~ ^archived_skills: ]]; then _in_archived=true; continue; fi
  if $_in_archived; then
    if [[ "$line" =~ ^[[:space:]]+-[[:space:]]+(.*) ]]; then
      ARCHIVED_SKILLS+=("${BASH_REMATCH[1]}")
    elif [[ ! "$line" =~ ^[[:space:]] && ! "$line" =~ ^$ && ! "$line" =~ ^# ]]; then
      break
    fi
  fi
done < "$CONFIG"

is_archived() {
  local name="$1"
  for a in "${ARCHIVED_SKILLS[@]+"${ARCHIVED_SKILLS[@]}"}"; do
    [[ "$a" == "$name" ]] && return 0
  done
  return 1
}

# 双源合并：扫描各仓库 _archived/ 目录，追加到归档集合
_scan_archived_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || return
  for _d in "$dir"/*/; do
    [[ -d "$_d" ]] || continue
    local _name
    _name=$(basename "$_d")
    if ! is_archived "$_name"; then
      ARCHIVED_SKILLS+=("$_name")
    fi
  done
}

[[ -n "$SKILLS_PATH" ]] && _scan_archived_dir "$SKILLS_PATH/_archived"
[[ -n "$ENV_PATH" ]]    && _scan_archived_dir "$ENV_PATH/skills/_archived"

# 回写 archived_skills 到 prism.local.yaml（仅当配置已声明该段；缺省不 surprise 写盘）
_sync_archived_yaml() {
  [[ ${#ARCHIVED_SKILLS[@]} -eq 0 ]] && return
  grep -q '^archived_skills:' "$CONFIG" 2>/dev/null || return
  $CHECK_ONLY && return
  $DRY_RUN && return

  local tmp="${CONFIG}.tmp.$$"
  # 删除旧 archived_skills 段
  awk '
    /^archived_skills:/ { skip=1; next }
    skip && /^[[:space:]]/ { next }
    skip && !/^[[:space:]]/ { skip=0 }
    { print }
  ' "$CONFIG" > "$tmp"

  # 移除尾部多余空行
  sed -i '' -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$tmp" 2>/dev/null || true

  # 追加新段（排序去重保持可读性）
  echo "" >> "$tmp"
  echo "archived_skills:" >> "$tmp"
  printf '%s\n' "${ARCHIVED_SKILLS[@]}" | sort -u | while read -r name; do
    echo "  - ${name}" >> "$tmp"
  done

  mv "$tmp" "$CONFIG"
}
_sync_archived_yaml

is_platform_blocked() {
  local skill_dir="$1"
  local platform="$2"
  local blacklist_file="$skill_dir/.blacklist"
  
  [[ -f "$blacklist_file" ]] || return 1
  
  grep -q "^${platform}$" "$blacklist_file"
}

log_ok()    { echo -e "  ${GREEN}✓${NC} $1"; ((OK++)) || true; ((TOTAL++)) || true; }
log_fix()   { echo -e "  ${GREEN}⟳${NC} $1"; ((FIXED++)) || true; ((TOTAL++)) || true; }
log_skip()  { echo -e "  ${DIM}⊘${NC} $1"; ((TOTAL++)) || true; }
log_warn()  { echo -e "  ${YELLOW}⚠${NC} $1"; ((TOTAL++)) || true; }
log_err()   { echo -e "  ${RED}✗${NC} $1"; ((ERRORS++)) || true; ((TOTAL++)) || true; }

ensure_link() {
  local link_path="$1"
  local target="$2"
  local label="$3"

  if [[ ! -d "$target" && ! -f "$target" ]]; then
    log_err "${label}: 目标不存在 ${DIM}${target}${NC}"
    return
  fi

  if [[ -L "$link_path" ]]; then
    local current
    current=$(readlink "$link_path")
    if [[ "$current" == "$target" ]]; then
      log_ok "${label} ${DIM}→ ${target}${NC}"
      return
    fi

    # 冲突检测：链接指向非 Prism 路径时警告（含 env 层）
    if [[ "$current" != *prism* && ( -z "$SKILLS_PATH" || "$current" != "$SKILLS_PATH"* ) && "$current" != "$WS_ROOT"* && ( -z "$ENV_PATH" || "$current" != "$ENV_PATH"* ) ]]; then
      log_warn "${label}: 已有非 Prism 链接 ${DIM}${current}${NC}，跳过覆盖"
      return
    fi

    if $CHECK_ONLY; then
      log_warn "${label}: 指向错误 ${DIM}${current} ≠ ${target}${NC}"
      return
    fi

    if $DRY_RUN; then
      log_fix "${label}: 将更新 ${DIM}${current} → ${target}${NC}"
      return
    fi

    ln -sfn "$target" "$link_path"
    log_fix "${label}: 已更新 ${DIM}→ ${target}${NC}"
    return
  fi

  if [[ -e "$link_path" ]]; then
    log_err "${label}: 存在同名普通文件，请手动处理 ${DIM}${link_path}${NC}"
    return
  fi

  if $CHECK_ONLY; then
    log_warn "${label}: 不存在 ${DIM}${link_path}${NC}"
    return
  fi

  if $DRY_RUN; then
    log_fix "${label}: 将创建 ${DIM}→ ${target}${NC}"
    return
  fi

  ln -sfn "$target" "$link_path"
  log_fix "${label}: 已创建 ${DIM}→ ${target}${NC}"
}

_relink_writeback_path() {
  local proj_yaml="$1" device_id="$2" local_path="$3"
  [[ -f "$proj_yaml" ]] || return 0
  # 已有当前设备条目则跳过
  if grep -Fq "  ${device_id}:" "$proj_yaml" 2>/dev/null; then
    return 0
  fi

  # 检测 paths 格式
  local in_paths=false has_paths=false has_map=false has_list=false
  while IFS= read -r line; do
    if [[ "$line" =~ ^paths: ]]; then in_paths=true; has_paths=true; continue; fi
    if $in_paths; then
      if [[ "$line" =~ ^[[:space:]]+-[[:space:]] ]]; then has_list=true; fi
      if [[ "$line" =~ ^[[:space:]]+[A-Za-z0-9_-]+:[[:space:]] ]]; then has_map=true; fi
      if [[ ! "$line" =~ ^[[:space:]] ]]; then break; fi
    fi
  done < "$proj_yaml"

  if $has_map; then
    # paths 段有 map 条目：在段末追加新设备条目
    local tmp="${proj_yaml}.tmp.$$"
    awk -v did="$device_id" -v lp="$local_path" '
      /^paths:/ { in_paths=1; print; next }
      in_paths && /^[^ ]/ && !/^  / {
        print "  " did ": " lp
        in_paths=0
      }
      { print }
      END { if (in_paths) print "  " did ": " lp }
    ' "$proj_yaml" > "$tmp" && mv "$tmp" "$proj_yaml"
  elif $has_list; then
    # paths 段有 list 条目：转为 map 格式
    local tmp="${proj_yaml}.tmp.$$"
    awk -v did="$device_id" -v lp="$local_path" '
      /^paths:/ { in_paths=1; print; next }
      in_paths && /^  - / { sub(/^  - /, "  # (legacy) "); print; next }
      in_paths && /^[^ ]/ && !/^  / {
        if (!wrote) { print "  " did ": " lp; wrote=1 }
        in_paths=0
      }
      { print }
      END { if (in_paths && !wrote) print "  " did ": " lp }
    ' "$proj_yaml" > "$tmp" && mv "$tmp" "$proj_yaml"
  elif $has_paths; then
    # paths 段存在但无有效条目（纯注释或空）：在现有 paths 段下追加
    local tmp="${proj_yaml}.tmp.$$"
    awk -v did="$device_id" -v lp="$local_path" '
      /^paths:/ { in_paths=1; print; next }
      in_paths && /^[^ ]/ && !/^  / {
        print "  " did ": " lp
        in_paths=0
      }
      { print }
      END { if (in_paths) print "  " did ": " lp }
    ' "$proj_yaml" > "$tmp" && mv "$tmp" "$proj_yaml"
  else
    # 完全没有 paths 段：追加新段
    echo "" >> "$proj_yaml"
    echo "paths:" >> "$proj_yaml"
    echo "  ${device_id}: ${local_path}" >> "$proj_yaml"
  fi
}

echo -e "${CYAN}Prism Relink${NC}"
if $CHECK_ONLY; then
  echo -e "${DIM}模式: 仅检查${NC}"
elif $DRY_RUN; then
  echo -e "${DIM}模式: 预览（不实际修改）${NC}"
fi
echo "─────────────────────────────────"

# 1. 检查基础路径
echo -e "\n${CYAN}[路径检查]${NC}"
[[ -d "$SDK_PATH" ]] && log_ok "SDK: ${SDK_PATH}" || log_err "SDK 不存在: ${SDK_PATH}"
if [[ -n "$SKILLS_PATH" && -d "$SKILLS_PATH" ]]; then
  log_ok "Skills: ${SKILLS_PATH}"
elif [[ -n "$SKILLS_PATH" ]]; then
  log_skip "Skills: ${SKILLS_PATH} ${DIM}(未配置或不存在，跳过外部技能)${NC}"
else
  log_skip "Skills: ${DIM}(未配置 skills_path，跳过外部技能)${NC}"
fi
[[ -d "$VAULT_PATH" ]] && log_ok "Vault: ${VAULT_PATH}" || log_err "Vault 不存在: ${VAULT_PATH}"

if [[ ! -d "$WS_ROOT" ]]; then
  if $CHECK_ONLY || $DRY_RUN; then
    log_warn "Workspace 根目录不存在: ${WS_ROOT}"
  else
    mkdir -p "$WS_ROOT"
    log_fix "已创建 Workspace 根目录: ${WS_ROOT}"
  fi
else
  log_ok "Workspace: ${WS_ROOT}"
fi

# 2. 刷新项目软链接（多 workspace：按 CODE 解析 instance_path）
echo -e "\n${CYAN}[项目软链接]${NC}"
_relink_projects=false
if _resolver_out=$(_run_resolver_tsv); then
  _relink_projects=true
  while IFS=$'\t' read -r code local_path ws_target workspace_id; do
    [[ -z "$code" ]] && continue
    if [[ -n "$TARGET_PROJECT" && "$code" != "$TARGET_PROJECT" ]]; then
      continue
    fi

    code_lower=$(echo "$code" | tr '[:upper:]' '[:lower:]')
    echo -e "  ${CYAN}${code}${NC} (${local_path}) ${DIM}[${workspace_id}]${NC}"

    ws_link="${local_path}/workspace.${code_lower}.local"
    ensure_link "$ws_link" "$ws_target" "    workspace.${code_lower}.local"

    agents_target="${ws_target}/AGENTS.md"
    legacy_target="${ws_target}/AGENT.md"
    if [[ -f "$legacy_target" && -f "$agents_target" ]]; then
      log_warn "    ${code}: vault 内同时存在 AGENT.md 与 AGENTS.md，请手动确认后保留 AGENTS.md"
    elif [[ -f "$legacy_target" && ! -f "$agents_target" ]]; then
      if $CHECK_ONLY; then
        log_warn "    ${code}: vault 内仍是老命名 AGENT.md（v1.1.4+ 应已迁移；运行 bin/relink 自动 mv）"
      elif $DRY_RUN; then
        log_fix "    ${code}: 将 mv ${legacy_target} → ${agents_target}"
      else
        if mv "$legacy_target" "$agents_target" 2>/dev/null; then
          log_fix "    ${code}: 自动迁移 AGENT.md → AGENTS.md（vault 内）"
        else
          log_err "    ${code}: AGENT.md → AGENTS.md mv 失败（iCloud 占位符？请手动处理）"
        fi
      fi
    fi
    if [[ -f "$agents_target" ]]; then
      ensure_link "${local_path}/AGENTS.local.md" "$agents_target" "    AGENTS.local.md"
    fi

    if [[ -n "$DEVICE_ID" && -d "$ws_target" ]] && ! $CHECK_ONLY && ! $DRY_RUN; then
      _relink_writeback_path "${ws_target}/project.yaml" "$DEVICE_ID" "$local_path"
    fi
  done <<< "$_resolver_out"
fi

if ! $_relink_projects; then
in_projects=false
while IFS= read -r line; do
  if [[ "$line" == "projects:" ]]; then
    in_projects=true
    continue
  fi

  if $in_projects; then
    if [[ "$line" =~ ^[[:space:]]+([A-Za-z0-9_-]+):[[:space:]]*(.*) ]]; then
      code="${BASH_REMATCH[1]}"
      local_path="${BASH_REMATCH[2]}"
      code_lower=$(echo "$code" | tr '[:upper:]' '[:lower:]')

      if [[ -n "$TARGET_PROJECT" && "$code" != "$TARGET_PROJECT" ]]; then
        continue
      fi

      echo -e "  ${CYAN}${code}${NC} (${local_path})"

      ws_target="${WS_ROOT}/${code}"
      ws_link="${local_path}/workspace.${code_lower}.local"
      ensure_link "$ws_link" "$ws_target" "    workspace.${code_lower}.local"

      agents_target="${WS_ROOT}/${code}/AGENTS.md"
      legacy_target="${WS_ROOT}/${code}/AGENT.md"
      if [[ -f "$legacy_target" && -f "$agents_target" ]]; then
        log_warn "    ${code}: vault 内同时存在 AGENT.md 与 AGENTS.md，请手动确认后保留 AGENTS.md"
      elif [[ -f "$legacy_target" && ! -f "$agents_target" ]]; then
        if $CHECK_ONLY; then
          log_warn "    ${code}: vault 内仍是老命名 AGENT.md（v1.1.4+ 应已迁移；运行 bin/relink 自动 mv）"
        elif $DRY_RUN; then
          log_fix "    ${code}: 将 mv ${legacy_target} → ${agents_target}"
        else
          if mv "$legacy_target" "$agents_target" 2>/dev/null; then
            log_fix "    ${code}: 自动迁移 AGENT.md → AGENTS.md（vault 内）"
          else
            log_err "    ${code}: AGENT.md → AGENTS.md mv 失败（iCloud 占位符？请手动处理）"
          fi
        fi
      fi
      if [[ -f "$agents_target" ]]; then
        ensure_link "${local_path}/AGENTS.local.md" "$agents_target" "    AGENTS.local.md"
      fi

      if [[ -n "$DEVICE_ID" && -d "$ws_target" ]] && ! $CHECK_ONLY && ! $DRY_RUN; then
        _relink_writeback_path "${ws_target}/project.yaml" "$DEVICE_ID" "$local_path"
      fi

    elif [[ ! "$line" =~ ^[[:space:]] ]]; then
      break
    fi
  fi
done < "$CONFIG"
fi

# 3. 探测可用 IDE 平台目录
PLATFORM_TARGETS=()
[[ -d "$HOME/.cursor/skills-cursor" ]] && PLATFORM_TARGETS+=("cursor|$HOME/.cursor/skills-cursor")
[[ -d "$HOME/.claude/skills" ]] && PLATFORM_TARGETS+=("claude|$HOME/.claude/skills")
[[ -d "$HOME/.claude-internal/skills" ]] && PLATFORM_TARGETS+=("claude-internal|$HOME/.claude-internal/skills")
[[ -d "$HOME/.codex/skills" ]] && PLATFORM_TARGETS+=("codex|$HOME/.codex/skills")
[[ -d "$HOME/.codebuddy/skills" ]] && PLATFORM_TARGETS+=("codebuddy|$HOME/.codebuddy/skills")
[[ -d "$HOME/.codebuddy/commands" ]] && PLATFORM_TARGETS+=("codebuddy-cli|$HOME/.codebuddy/commands")
[[ -d "$HOME/.workbuddy/skills" ]] && PLATFORM_TARGETS+=("workbuddy|$HOME/.workbuddy/skills")
[[ -d "$HOME/.workbuddy/commands" ]] && PLATFORM_TARGETS+=("workbuddy-cli|$HOME/.workbuddy/commands")

if [[ ${#PLATFORM_TARGETS[@]} -eq 0 ]]; then
  echo -e "\n${CYAN}[Agent/IDE 映射]${NC}"
  log_skip "未探测到可用平台目录，跳过所有 Skills 映射"
fi

# 3a. SDK 内置技能分发（workflow-* / workspace-*）
if [[ ${#PLATFORM_TARGETS[@]} -gt 0 ]]; then
  echo -e "\n${CYAN}[SDK 内置技能 → Agent/IDE]${NC}"
  sdk_skill_count=0
  for category in workflow workspace; do
    category_dir="$SDK_PATH/skills/${category}"
    [[ -d "$category_dir" ]] || continue
    for skill_dir in "$category_dir"/*/; do
      [[ -d "$skill_dir" ]] || continue
      skill_name=$(basename "$skill_dir")
      [[ "$skill_name" == "shared" ]] && continue
      [[ ! -f "$skill_dir/SKILL.md" ]] && continue
      # 目录名已与 frontmatter name / IDE 分发 id 对齐（workflow-archive 等）
      if [[ "$skill_name" == "${category}-"* ]]; then
        link_name="$skill_name"
      else
        link_name="${category}-${skill_name}"
      fi

      if is_archived "$link_name"; then
        log_skip "${link_name} ${DIM}(archived)${NC}"
        ((SKIPPED_ARCHIVED++)) || true
        continue
      fi

      ((sdk_skill_count++)) || true

      for target in "${PLATFORM_TARGETS[@]}"; do
        platform="${target%%|*}"
        root_dir="${target#*|}"
        
        # 检查平台黑名单
        if is_platform_blocked "$skill_dir" "$platform"; then
          log_skip "${link_name} ${DIM}(平台 ${platform} 黑名单)${NC}"
          continue
        fi
        
        link_path="${root_dir}/${link_name}"
        ensure_link "$link_path" "$skill_dir" "${platform}: ${link_name}"
      done
    done
  done

  if [[ $sdk_skill_count -eq 0 ]]; then
    log_skip "SDK 内置技能目录为空"
  fi
fi

# 3b. 外部 Skills 分发（prism-skills 仓库）
if [[ ${#PLATFORM_TARGETS[@]} -gt 0 ]]; then
  echo -e "\n${CYAN}[外部 Skills → Agent/IDE]${NC}"
  if [[ -d "$SKILLS_PATH" ]]; then
    skill_count=0
    for skill_dir in "$SKILLS_PATH"/*/; do
      [[ -d "$skill_dir" ]] || continue
      skill_name=$(basename "$skill_dir")
      [[ "$skill_name" == ".git" ]] && continue
      [[ "$skill_name" == "shared" ]] && continue
      [[ ! -f "$skill_dir/SKILL.md" ]] && continue

      if is_archived "$skill_name"; then
        log_skip "${skill_name} ${DIM}(archived)${NC}"
        ((SKIPPED_ARCHIVED++)) || true
        continue
      fi

      ((skill_count++)) || true

      for target in "${PLATFORM_TARGETS[@]}"; do
        platform="${target%%|*}"
        root_dir="${target#*|}"
        
        # 检查平台黑名单
        if is_platform_blocked "$skill_dir" "$platform"; then
          log_skip "${skill_name} ${DIM}(平台 ${platform} 黑名单)${NC}"
          continue
        fi
        
        link_path="${root_dir}/${skill_name}"
        ensure_link "$link_path" "$skill_dir" "${platform}: ${skill_name}"
      done
    done

    if [[ $skill_count -eq 0 ]]; then
      log_skip "外部 Skills 目录为空"
    fi
  else
    log_skip "外部 Skills 未配置或不存在，跳过"
  fi
fi

# 3c. env 层 Skills 分发（可选，env_path/skills/ 存在时执行）
if [[ ${#PLATFORM_TARGETS[@]} -gt 0 ]]; then
  if [[ -n "$ENV_PATH" && -d "$ENV_PATH/skills" ]]; then
    echo -e "\n${CYAN}[env 层 Skills → Agent/IDE]${NC}"
    env_skill_count=0
    for skill_dir in "$ENV_PATH/skills"/*/; do
      [[ -d "$skill_dir" ]] || continue
      skill_name=$(basename "$skill_dir")
      [[ "$skill_name" == ".git" ]] && continue
      [[ ! -f "$skill_dir/SKILL.md" ]] && continue

      if is_archived "$skill_name"; then
        log_skip "${skill_name} ${DIM}(archived)${NC}"
        ((SKIPPED_ARCHIVED++)) || true
        continue
      fi

      ((env_skill_count++)) || true

      for target in "${PLATFORM_TARGETS[@]}"; do
        platform="${target%%|*}"
        root_dir="${target#*|}/"
        
        # 检查平台黑名单
        if is_platform_blocked "$skill_dir" "$platform"; then
          log_skip "${skill_name} ${DIM}(平台 ${platform} 黑名单)${NC}"
          continue
        fi
        
        link_path="${root_dir}/${skill_name}"
        ensure_link "$link_path" "$skill_dir" "${platform}: ${skill_name}"
      done
    done

    if [[ $env_skill_count -eq 0 ]]; then
      log_skip "env 层 Skills 目录为空"
    fi
  elif [[ -n "$ENV_PATH" ]]; then
    log_skip "env 层路径不存在或无 skills/ 目录: ${ENV_PATH} ${DIM}(可选，跳过)${NC}"
  fi
fi

# 3d. 归档反解：主动清除已归档技能在各平台的 symlink（无需 --prune）
UNLINKED_ARCHIVED=0
if [[ ${#ARCHIVED_SKILLS[@]} -gt 0 && ${#PLATFORM_TARGETS[@]} -gt 0 ]]; then
  _has_unlink_output=false
  for target in "${PLATFORM_TARGETS[@]}"; do
    platform="${target%%|*}"
    root_dir="${target#*|}"
    for archived_name in "${ARCHIVED_SKILLS[@]}"; do
      link_path="${root_dir}/${archived_name}"
      if [[ -L "$link_path" ]]; then
        if ! $_has_unlink_output; then
          echo -e "\n${CYAN}[归档反解]${NC}"
          _has_unlink_output=true
        fi
        if $CHECK_ONLY; then
          log_warn "${platform}: ${archived_name} 已归档但链接仍在"
        elif $DRY_RUN; then
          echo -e "  ${YELLOW}⌫${NC} ${platform}: ${archived_name} ${DIM}(归档，将反解)${NC}"
        else
          rm "$link_path"
          echo -e "  ${YELLOW}⌫${NC} ${platform}: ${archived_name} ${DIM}(归档，已反解)${NC}"
        fi
        ((UNLINKED_ARCHIVED++)) || true
      fi
    done
  done
fi

# 4. Prune: 清理陈旧软链接
PRUNED=0
if $PRUNE; then
  echo -e "\n${CYAN}[Prune 陈旧链接]${NC}"

  prune_link() {
    local link="$1" label="$2"
    if $DRY_RUN; then
      echo -e "  ${YELLOW}⌫${NC} ${label}: 将删除 ${DIM}$(readlink "$link")${NC}"
    else
      rm "$link"
      echo -e "  ${YELLOW}⌫${NC} ${label}: 已删除 ${DIM}$(basename "$link")${NC}"
    fi
    ((PRUNED++)) || true
  }

  # 4a. IDE 平台目录：清理 Prism 管辖范围内的陈旧链接
  for target in ${PLATFORM_TARGETS[@]+"${PLATFORM_TARGETS[@]}"}; do
    platform="${target%%|*}"
    root_dir="${target#*|}"
    for link in "$root_dir"/*; do
      [[ -L "$link" ]] || continue
      link_target=$(readlink "$link")
      # SDK 内置技能（指向 prism/skills/）
      if [[ "$link_target" == "$SDK_PATH/skills/"* ]]; then
        if [[ ! -d "$link_target" ]] || [[ ! -f "$link_target/SKILL.md" ]]; then
          prune_link "$link" "${platform}: $(basename "$link")"
        fi
      # 外部 Skills（指向 prism-skills/）
      elif [[ -n "$SKILLS_PATH" && "$link_target" == "$SKILLS_PATH"* ]] || [[ "$link_target" == *prism-skills* ]]; then
        if [[ ! -d "$link_target" ]] || [[ ! -f "$link_target/SKILL.md" ]]; then
          prune_link "$link" "${platform}: $(basename "$link")"
        fi
      # env 层 Skills（指向 env_path/skills/）
      elif [[ -n "$ENV_PATH" && "$link_target" == "$ENV_PATH/skills/"* ]]; then
        if [[ ! -d "$link_target" ]] || [[ ! -f "$link_target/SKILL.md" ]]; then
          prune_link "$link" "${platform}: $(basename "$link")"
        fi
      fi
    done
  done

  # 4b. 项目目录：清理指向 WS_ROOT 下已不存在 Workspace 的桥接链接
  in_projects=false
  while IFS= read -r line; do
    if [[ "$line" == "projects:" ]]; then
      in_projects=true
      continue
    fi
    if $in_projects; then
      if [[ "$line" =~ ^[[:space:]]+([A-Za-z0-9_-]+):[[:space:]]*(.*) ]]; then
        local_path="${BASH_REMATCH[2]}"
        [[ -d "$local_path" ]] || continue
        # 扫描 workspace.*.local 和 AGENTS.local.md
        for link in "$local_path"/workspace.*.local "$local_path"/AGENTS.local.md; do
          [[ -L "$link" ]] || continue
          link_target=$(readlink "$link")
          if [[ ! -e "$link_target" ]]; then
            prune_link "$link" "项目: $(basename "$link")"
          fi
        done
      elif [[ ! "$line" =~ ^[[:space:]] ]]; then
        break
      fi
    fi
  done < "$CONFIG"

  if [[ $PRUNED -eq 0 ]]; then
    echo -e "  ${GREEN}✓${NC} 无陈旧链接"
  fi
fi

# 5. 汇总
echo ""
echo "─────────────────────────────────"
ARCHIVE_LABEL=""
[[ $SKIPPED_ARCHIVED -gt 0 ]] && ARCHIVE_LABEL="  ${DIM}归档跳过: ${SKIPPED_ARCHIVED}${NC}"
[[ $UNLINKED_ARCHIVED -gt 0 ]] && ARCHIVE_LABEL="${ARCHIVE_LABEL}  ${YELLOW}归档反解: ${UNLINKED_ARCHIVED}${NC}"

if [[ $PRUNED -gt 0 ]]; then
  echo -e "  检查项: ${TOTAL}  ${GREEN}正常: ${OK}${NC}  ${GREEN}修复: ${FIXED}${NC}  ${YELLOW}清理: ${PRUNED}${NC}  ${RED}错误: ${ERRORS}${NC}${ARCHIVE_LABEL}"
else
  echo -e "  检查项: ${TOTAL}  ${GREEN}正常: ${OK}${NC}  ${GREEN}修复: ${FIXED}${NC}  ${RED}错误: ${ERRORS}${NC}${ARCHIVE_LABEL}"
fi

if [[ $ERRORS -gt 0 ]]; then
  echo -e "  ${RED}存在错误，请检查上述输出。${NC}"
  exit 1
fi

if $CHECK_ONLY && [[ $FIXED -gt 0 ]]; then
  echo -e "  ${YELLOW}发现需要修复的项，运行 bin/relink 修复。${NC}"
fi
