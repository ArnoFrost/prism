#!/usr/bin/env bash
# Prism validate-skills — 扫描三层所有 skill 的 frontmatter 合规性和引用完整性。
#
# 用法:
#   bin/validate-skills              扫描并报告（不修改）
#   bin/validate-skills --fix        自动修复机械性缺失（visibility/stability 默认值）
#   bin/validate-skills --json       输出 JSON 格式报告
#   bin/validate-skills --layer sdk  仅扫描 SDK 层
#
# 退出码:
#   0  全部合规
#   1  存在 ERROR

set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PRISM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG="$PRISM_DIR/prism.local.yaml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

FIX=false
JSON=false
FILTER_LAYER=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --fix)    FIX=true; shift ;;
    --json)   JSON=true; shift ;;
    --layer)
      [[ $# -lt 2 ]] && { echo -e "${RED}✗ --layer 需要参数${NC}" >&2; exit 1; }
      FILTER_LAYER="$2"; shift 2 ;;
    --help|-h)
      sed -n '2,/^$/{ s/^# //; s/^#//; p }' "$0"
      exit 0 ;;
    *) echo -e "${RED}✗ 未知参数: $1${NC}" >&2; exit 1 ;;
  esac
done

yaml_get() {
  (grep "^${1}:" "$CONFIG" 2>/dev/null || true) | tail -1 | sed "s/^${1}: *//"
}

# ── 收集所有 skill 路径 ──────────────

SKILLS=()
LABELS=()

# SDK 内置
if [[ -z "$FILTER_LAYER" || "$FILTER_LAYER" == "sdk" ]]; then
  while IFS= read -r f; do
    dir=$(dirname "$f")
    SKILLS+=("$dir")
    LABELS+=("sdk")
  done < <(find "$PRISM_DIR/skills" -name "SKILL.md" -maxdepth 4 2>/dev/null | sort)
fi

# 外部 skills
if [[ -z "$FILTER_LAYER" || "$FILTER_LAYER" == "skills" ]]; then
  SKILLS_PATH=$(yaml_get skills_path)
  if [[ -n "$SKILLS_PATH" && -d "$SKILLS_PATH" ]]; then
    for d in "$SKILLS_PATH"/*/; do
      [[ -f "$d/SKILL.md" ]] || continue
      name=$(basename "$d")
      [[ "$name" == _* || "$name" == docs || "$name" == shared ]] && continue
      SKILLS+=("${d%/}")
      LABELS+=("skills")
    done
  fi
fi

# Env 层
if [[ -z "$FILTER_LAYER" || "$FILTER_LAYER" == "env" ]]; then
  ENV_PATH=$(yaml_get env_path)
  if [[ -n "$ENV_PATH" && -d "$ENV_PATH/skills" ]]; then
    for d in "$ENV_PATH/skills"/*/; do
      [[ -f "$d/SKILL.md" ]] || continue
      SKILLS+=("${d%/}")
      LABELS+=("env")
    done
  fi
fi

# ── frontmatter 解析函数 ─────────────

# 从 SKILL.md 提取 frontmatter 中某字段的值
fm_get() {
  local file="$1" key="$2"
  sed -n '2,/^---$/p' "$file" | grep "^${key}:" | head -1 | sed "s/^${key}: *//" | tr -d '"' | tr -d "'"
}

# 检查 description 是否包含 "Use when:"
fm_has_use_when() {
  local file="$1"
  sed -n '2,/^---$/p' "$file" | grep -qi "use when:" && return 0 || return 1
}

CATALOG_FILE="$PRISM_DIR/skills/schema/skills-catalog.yaml"

# 从 skills-catalog.yaml 读取某 id 的 visibility / stability（SDK 治理 SSOT）
catalog_field() {
  local id="$1" key="$2"
  [[ -f "$CATALOG_FILE" ]] || return 0
  awk -v id="$id" -v key="$key" '
    $0 ~ "^  - id: " id "$" { in_entry=1; next }
    in_entry && /^  - id:/ { exit }
    in_entry && $1 == key ":" { print $2; exit }
  ' "$CATALOG_FILE"
}

# 在 frontmatter 尾部（第二个 `---` 之前）插入一行，兼容任何 frontmatter 布局。
# 旧实现依赖 `stability:` / `user_invocable:` / `license:` 作为锚点，对极简
# frontmatter（只有 name + disable）会静默失败。
_insert_into_frontmatter() {
  local file="$1"
  local line_to_insert="$2"
  # 定位第二个 `---` 的行号（frontmatter 结束）
  local end_line
  end_line=$(awk '/^---$/{c++; if(c==2){print NR; exit}}' "$file")
  [[ -z "$end_line" ]] && return 1
  # 在该行**之前**插入
  sed -i '' "${end_line}i\\
${line_to_insert}
" "$file"
}

# ── 校验逻辑 ─────────────────────────

TOTAL=0
ERRORS=0
WARNINGS=0
FIXED=0
ERROR_SKILLS=()

if ! $JSON; then
  echo -e "${CYAN}Prism Validate-Skills${NC}"
  echo "─────────────────────────────────"
fi

for i in "${!SKILLS[@]}"; do
  set +e  # 循环内允许非零退出码（grep 无匹配返回 1）
  dir="${SKILLS[$i]}"
  layer="${LABELS[$i]}"
  file="$dir/SKILL.md"
  name=$(basename "$dir")
  TOTAL=$((TOTAL + 1))

  # 检查是否有 frontmatter（以 --- 开头）
  if ! head -1 "$file" | grep -q '^---$'; then
    if ! $JSON; then
      echo -e "  ${DIM}⊘${NC} ${name} ${DIM}(${layer}) — 无 frontmatter，跳过${NC}"
    fi
    continue
  fi

  skill_errors=()
  skill_warnings=()
  skill_fixes=()

  # 1. name 字段（须与分发 id / 父目录名一致 — 见 skill.schema.yaml §naming）
  fm_name=$(fm_get "$file" "name")
  parent_cat=$(basename "$(dirname "$dir")")
  if [[ -z "$fm_name" ]]; then
    skill_errors+=("缺失 name 字段")
  elif ! echo "$fm_name" | grep -qE '^[a-z][a-z0-9-]*$' 2>/dev/null; then
    skill_errors+=("name 格式错误: $fm_name（要求小写+连字符）")
  elif [[ "$parent_cat" == "workflow" || "$parent_cat" == "workspace" ]]; then
    if [[ "$fm_name" != "$name" ]]; then
      skill_errors+=("name '$fm_name' 必须与父目录 '$name' 一致（SDK 内置技能目录名 = 分发 id）")
    fi
  elif [[ "$fm_name" != "$name" ]]; then
    skill_errors+=("name '$fm_name' 必须与父目录 '$name' 一致")
  fi

  # 2. description 字段 + Use when
  fm_desc=$(fm_get "$file" "description")
  if [[ -z "$fm_desc" && "$fm_desc" != "|" ]]; then
    # 检查多行 description
    has_desc=$(sed -n '2,/^---$/p' "$file" | grep -c "^description:" || true)
    if [[ "$has_desc" -eq 0 ]]; then
      skill_errors+=("缺失 description 字段")
    fi
  fi
  if ! fm_has_use_when "$file"; then
    skill_warnings+=("description 中缺少 'Use when:' 关键词")
  fi

  # 2b. description_zh（SDK workflow/workspace 必填 — frontmatter-spec §A）
  fm_desc_zh=$(fm_get "$file" "description_zh")
  if [[ "$layer" == "sdk" && -z "$fm_desc_zh" ]]; then
    skill_warnings+=("缺失 description_zh（CodeBuddy IDE 列表；见 frontmatter-spec.md）")
  fi

  # 2c. user_invocable 布尔字面量
  fm_ui=$(fm_get "$file" "user_invocable")
  if [[ -n "$fm_ui" && "$fm_ui" != "true" && "$fm_ui" != "false" && "$fm_ui" != "True" && "$fm_ui" != "False" ]]; then
    skill_warnings+=("user_invocable 应为 true/false 小写，当前: $fm_ui")
  elif [[ "$fm_ui" == "True" || "$fm_ui" == "False" ]]; then
    skill_warnings+=("user_invocable 请用小写 true/false（非 Python True）")
  fi

  cat_vis=$(catalog_field "$fm_name" "visibility")
  cat_stab=$(catalog_field "$fm_name" "stability")

  # 3. visibility（catalog 有条目时 SSOT；SKILL 可省略或须一致）
  fm_vis=$(fm_get "$file" "visibility")
  if [[ -n "$cat_vis" ]]; then
    if [[ -n "$fm_vis" && "$fm_vis" != "$cat_vis" ]]; then
      skill_errors+=("visibility=$fm_vis 与 skills-catalog.yaml 不一致（catalog=$cat_vis）")
    fi
    [[ -z "$fm_vis" ]] && fm_vis="$cat_vis"
  elif [[ -z "$fm_vis" ]]; then
    skill_warnings+=("缺失 visibility（默认 internal；见 frontmatter-spec）")
    if $FIX; then
      _insert_into_frontmatter "$file" "visibility: internal"
      if fm_get "$file" "visibility" | grep -q "internal"; then
        skill_fixes+=("已补充 visibility: internal")
        FIXED=$((FIXED + 1))
      fi
    fi
  elif [[ "$fm_vis" != "internal" && "$fm_vis" != "public" && "$fm_vis" != "dev" ]]; then
    skill_errors+=("visibility 值非法: $fm_vis（应为 dev / internal / public）")
  fi

  # 4. stability
  fm_stab=$(fm_get "$file" "stability")
  if [[ -n "$cat_stab" ]]; then
    if [[ -n "$fm_stab" && "$fm_stab" != "$cat_stab" ]]; then
      skill_errors+=("stability=$fm_stab 与 skills-catalog.yaml 不一致（catalog=$cat_stab）")
    fi
    [[ -z "$fm_stab" ]] && fm_stab="$cat_stab"
  elif [[ -z "$fm_stab" ]]; then
    skill_warnings+=("缺失 stability（默认 experimental）")
    if $FIX; then
      _insert_into_frontmatter "$file" "stability: experimental"
      if fm_get "$file" "stability" | grep -q "experimental"; then
        skill_fixes+=("已补充 stability: experimental")
        FIXED=$((FIXED + 1))
      fi
    fi
  elif [[ "$fm_stab" != "experimental" && "$fm_stab" != "stable" ]]; then
    skill_errors+=("stability 值非法: $fm_stab（应为 experimental 或 stable）")
  fi

  # 5. public skill 的 public_gate 检查
  if [[ "$fm_vis" == "public" ]]; then
    fm_reviewed=$(fm_get "$file" "reviewed")
    has_gate=$(sed -n '2,/^---$/p' "$file" | grep -c "^public_gate:" || true)
    if [[ "$has_gate" -eq 0 ]]; then
      skill_warnings+=("public skill 缺少 public_gate 审计块")
    fi
  fi

  # 6. 引用完整性：检查 scripts/ 和 references/ 下的 symlink
  if [[ -d "$dir/scripts" ]]; then
    for link in "$dir/scripts"/*; do
      if [[ -L "$link" && ! -e "$link" ]]; then
        skill_errors+=("断裂 symlink: scripts/$(basename "$link")")
      fi
    done
  fi
  if [[ -d "$dir/references" ]]; then
    for link in "$dir/references"/*; do
      if [[ -L "$link" && ! -e "$link" ]]; then
        skill_errors+=("断裂 symlink: references/$(basename "$link")")
      fi
    done
  fi

  # 7. 双 frontmatter 检测
  #    标准 YAML frontmatter 含 1 个开块 + 1 个闭合块 = 文件头 2 个 `^---$` 行
  #    双 fm 模式：闭合块（第 2 个 `^---$`）后紧跟新的 `^---$` + yaml 字段（`name:` / `description:` 等）
  #    与 markdown horizontal rule（`---` 后跟空行 / 标题 / 正文）区分
  #
  # ── Heuristic 边界声明 ─────────────────────────────────────────────
  # "head 30 行" 假设：standard SKILL.md frontmatter ≤ 30 行（实测中位数 12 行；
  #                  最大值 ~25 行；30 行有 5 行余量）。
  # "后跟 yaml 字段（^[a-z_]+:）" 假设：双 fm bug 复制的内容必定包含 `name:` /
  #                  `description:` / `visibility:` 等 yaml 字段。
  #
  # Edge case 警告 — 以下场景需调用方避免，否则会被误判为双 fm：
  #   ① 正文 yaml 示例必须用 ``` 围栏包裹，禁止裸出 `^---$` + `^name:`
  #      （即 SKILL 教 yaml 用法时，示例代码要在 fenced code block 内）
  #   ② SKILL 主体严禁在 head 30 行内出现 markdown horizontal rule + 紧邻
  #      `^[a-z_]+:` 起头的列表项（罕见但理论可能）
  # ──────────────────────────────────────────────────────────────────
  third_fm=$(grep -n '^---$' "$file" | sed -n '3p' | cut -d: -f1)
  if [[ -n "$third_fm" && "$third_fm" -lt 30 ]]; then
    # 检查第 3 个 ^---$ 之后的非空行是否是 yaml 字段
    next_yaml_line=$(sed -n "$((third_fm + 1)),$((third_fm + 5))p" "$file" | grep -v '^$' | head -1)
    if [[ "$next_yaml_line" =~ ^[a-z_]+: ]]; then
      skill_errors+=("双 frontmatter 检测：第 3 个 \`^---$\` 在 line $third_fm，后跟 yaml 字段 '$next_yaml_line'（疑似 frontmatter 复制 bug）")
    fi
  fi

  # ── 输出 ──

  # 累加总数（JSON 模式也要统计）
  if [[ ${#skill_errors[@]} -gt 0 ]]; then
    ERRORS=$((ERRORS + ${#skill_errors[@]}))
    WARNINGS=$((WARNINGS + ${#skill_warnings[@]}))
    ERROR_SKILLS+=("$name")
  elif [[ ${#skill_warnings[@]} -gt 0 ]]; then
    WARNINGS=$((WARNINGS + ${#skill_warnings[@]}))
  fi

  if ! $JSON; then
    if [[ ${#skill_errors[@]} -gt 0 ]]; then
      echo -e "  ${RED}✗${NC} ${name} ${DIM}(${layer})${NC}"
      for e in "${skill_errors[@]}"; do echo -e "    ${RED}ERROR${NC}: $e"; done
      for w in "${skill_warnings[@]}"; do echo -e "    ${YELLOW}WARN${NC}: $w"; done
      for f in "${skill_fixes[@]}"; do echo -e "    ${GREEN}FIX${NC}: $f"; done
    elif [[ ${#skill_warnings[@]} -gt 0 ]]; then
      echo -e "  ${YELLOW}⚠${NC} ${name} ${DIM}(${layer})${NC}"
      for w in "${skill_warnings[@]}"; do echo -e "    ${YELLOW}WARN${NC}: $w"; done
      for f in "${skill_fixes[@]}"; do echo -e "    ${GREEN}FIX${NC}: $f"; done
    else
      echo -e "  ${GREEN}✓${NC} ${name} ${DIM}(${layer})${NC}"
    fi
  fi
done
set -e  # 恢复严格模式

# ── 汇总 ─────────────────────────────

if $JSON; then
  echo "{\"total\":$TOTAL,\"errors\":$ERRORS,\"warnings\":$WARNINGS,\"fixed\":$FIXED}"
else
  echo ""
  echo "─────────────────────────────────"
  echo -e "  扫描: ${TOTAL} 个 skill"
  if [[ $ERRORS -gt 0 ]]; then
    echo -e "  ${RED}ERROR: ${ERRORS}${NC}  ${YELLOW}WARN: ${WARNINGS}${NC}  ${GREEN}FIX: ${FIXED}${NC}"
    echo ""
    echo -e "  ${RED}不合规 skill: ${ERROR_SKILLS[*]}${NC}"
  elif [[ $WARNINGS -gt 0 ]]; then
    echo -e "  ${GREEN}ERROR: 0${NC}  ${YELLOW}WARN: ${WARNINGS}${NC}  ${GREEN}FIX: ${FIXED}${NC}"
  else
    echo -e "  ${GREEN}全部合规 ✓${NC}"
  fi

  if [[ $WARNINGS -gt 0 && ! $FIX ]]; then
    echo ""
    echo -e "  ${DIM}提示: 运行 bin/validate-skills --fix 自动修复可修复项${NC}"
  fi
fi

[[ $ERRORS -gt 0 ]] && exit 1 || exit 0
