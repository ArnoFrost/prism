#!/usr/bin/env bash
# Prism doctor — 统一健康检查入口，编排 setup / validate / sniff / relink 四件套。
#
# 用法:
#   bin/doctor                    完整体检（仓库+配置+链接+skill+同步状态）
#   bin/doctor --quick            快速模式，跳过访问远程的 sniff
#   bin/doctor --fix              非破坏性自动修复（validate --fix + relink + cli 注入）
#   bin/doctor --json             JSON 输出供其他 skill 消费
#   bin/doctor --scope <name>     只跑指定范围：env / config / link / skill / sync / cli / release
#
#   scope 说明:
#     env       setup --check 的环境完整性
#     skill     validate-skills 的 frontmatter 合规
#     sync      prism_sync_sniff 的远端同步
#     cli       doctor_cli 的 prism 寻址体检
#     config    prism.local.yaml 必填字段 + 路径可达性
#     release   聚合以上全部（1.0 发布就绪闸门）
#
# 退出码:
#   0  完全健康
#   1  有 ERROR（阻断性）
#   2  只有 WARN（不阻断但提示）

set -o pipefail  # 不要 set -e，避免 `! $JSON && echo` 写法触发误伤

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PRISM_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
NC='\033[0m'

QUICK=false
FIX=false
JSON=false
SCOPE=""

# 各阶段计数
ERR_ENV=0;    WARN_ENV=0
ERR_SKILL=0;  WARN_SKILL=0; FIX_SKILL=0
ERR_SYNC=0;   WARN_SYNC=0
ERR_CLI=0;    WARN_CLI=0;   FIX_CLI=0
ERR_CONFIG=0; WARN_CONFIG=0

# 解析参数
while [[ $# -gt 0 ]]; do
  case "$1" in
    --quick)  QUICK=true; shift ;;
    --fix)    FIX=true; shift ;;
    --json)   JSON=true; shift ;;
    --scope)
      [[ $# -lt 2 ]] && { echo -e "${RED}✗ --scope 需要参数${NC}" >&2; exit 1; }
      SCOPE="$2"; shift 2 ;;
    --help|-h)
      awk 'NR==1 { next } /^$/ { exit } { sub(/^# ?/, ""); print }' "$0"
      exit 0 ;;
    *) echo -e "${RED}✗ 未知参数: $1${NC}" >&2; exit 1 ;;
  esac
done

# ── 判定 scope 是否激活某阶段 ────────
# release scope 聚合全部 5 个阶段；普通 scope 只激活同名阶段
_in_scope() {
  [[ -z "$SCOPE" ]] && return 0
  [[ "$SCOPE" == "release" ]] && return 0
  [[ "$SCOPE" == "$1" ]] && return 0
  return 1
}

# ── Stage 1: 环境 (setup --check) ────
_stage_env() {
  _in_scope env || return 0

  ! $JSON && echo -e "\n${CYAN}[环境]${NC}"
  local out rc=0
  # setup 返回 0=全绿, 1=有错误, 其他视为错误
  out=$("$PRISM_DIR/bin/setup" --check 2>&1) || rc=$?

  # 显示非绿色行（日志里的 ✗ 或 ⚠ 开头项）
  if ! $JSON; then
    local noise
    noise=$(echo "$out" | grep -E '(✗|⚠)' 2>/dev/null | sed 's/^/  /' || true)
    if [[ -n "$noise" ]]; then
      echo "$noise"
    fi
  fi

  # 统计：先看退出码；同时尝试从输出末尾抓"N 个错误, N 个警告"模式（yellow 路径）
  local summary_line
  summary_line=$(echo "$out" | grep -oE '[0-9]+ 个错误, [0-9]+ 个警告' 2>/dev/null | tail -1 || true)
  if [[ -n "$summary_line" ]]; then
    ERR_ENV=$(echo "$summary_line" | awk '{print $1}')
    WARN_ENV=$(echo "$summary_line" | awk '{print $3}')
  else
    # 绿色路径：setup 返回 0 且无 summary_line
    ERR_ENV=0
    WARN_ENV=0
  fi
  # 如果 setup 返回非 0 但没抓到数字，兜底记 1 个错误
  if [[ $rc -ne 0 && $ERR_ENV -eq 0 ]]; then
    ERR_ENV=1
  fi

  ! $JSON && echo -e "  ${DIM}→ ${ERR_ENV} 错误, ${WARN_ENV} 警告${NC}"
}

# ── Stage 2: Skill 合规 (validate-skills) ─
_stage_skill() {
  _in_scope skill || return 0

  ! $JSON && echo -e "\n${CYAN}[Skill 合规]${NC}"
  local args=()
  $FIX && args+=("--fix")
  args+=("--json")

  local out rc=0
  out=$("$PRISM_DIR/bin/validate-skills" "${args[@]}" 2>&1) || rc=$?
  # validate-skills --json 最后一行为 JSON
  local json_line
  json_line=$(echo "$out" | tail -1)
  ERR_SKILL=$(echo "$json_line" | grep -oE '"errors":[0-9]+' | grep -oE '[0-9]+' | head -1)
  WARN_SKILL=$(echo "$json_line" | grep -oE '"warnings":[0-9]+' | grep -oE '[0-9]+' | head -1)
  FIX_SKILL=$(echo "$json_line" | grep -oE '"fixed":[0-9]+' | grep -oE '[0-9]+' | head -1)
  ERR_SKILL=${ERR_SKILL:-0}
  WARN_SKILL=${WARN_SKILL:-0}
  FIX_SKILL=${FIX_SKILL:-0}

  if ! $JSON; then
    if [[ $ERR_SKILL -gt 0 ]]; then
      echo -e "  ${RED}✗${NC} ${ERR_SKILL} 个 skill 有 ERROR 级问题"
      echo -e "  ${DIM}运行 bin/validate-skills 查看详情${NC}"
    fi
    if [[ $WARN_SKILL -gt 0 && $FIX_SKILL -eq 0 ]]; then
      echo -e "  ${YELLOW}⚠${NC} ${WARN_SKILL} 个 WARN 级问题（bin/doctor --fix 可自动修复部分）"
    fi
    if [[ $FIX_SKILL -gt 0 ]]; then
      echo -e "  ${GREEN}✓${NC} 已修复 ${FIX_SKILL} 项"
    fi
    [[ $ERR_SKILL -eq 0 && $WARN_SKILL -eq 0 ]] && echo -e "  ${GREEN}✓${NC} 全部合规"
    echo -e "  ${DIM}→ ${ERR_SKILL} 错误, ${WARN_SKILL} 警告, ${FIX_SKILL} 已修${NC}"
  fi
}

# ── Stage 3: 同步状态 (sniff --fetch) ──
_stage_sync() {
  _in_scope sync || return 0
  $QUICK && { ! $JSON && echo -e "\n${CYAN}[同步]${NC} ${DIM}(--quick 跳过，远程访问耗时)${NC}"; return 0; }

  ! $JSON && echo -e "\n${CYAN}[同步]${NC}"
  local sniff_script="$PRISM_DIR/skills/workflow/shared/scripts/prism_sync_sniff.py"
  if [[ ! -f "$sniff_script" ]]; then
    ! $JSON && echo -e "  ${YELLOW}⚠${NC} sniff 脚本不存在: $sniff_script"
    WARN_SYNC=$((WARN_SYNC + 1))
    return 0
  fi

  local out
  out=$(python3 "$sniff_script" --all --fetch 2>&1 || true)
  # 用 python 解析同步状态（stdin 管道，避免 heredoc 转义问题）
  local report
  report=$(echo "$out" | python3 -c '
import json, sys
raw = sys.stdin.read()
try:
    d = json.loads(raw)
except Exception:
    print("parse_error")
    sys.exit(0)
repos = d.get("repos", {})
err = 0
warn = 0
lines = []
for name, info in repos.items():
    if not info.get("exists"):
        lines.append(f"✗ {name}: 不存在")
        err += 1
        continue
    ahead = info.get("ahead", 0)
    behind = info.get("behind", 0)
    dirty = info.get("dirty", False)
    if ahead > 0 and behind > 0:
        lines.append(f"⚠ {name}: ahead={ahead} behind={behind}（分叉，需 pull --rebase）")
        warn += 1
    elif behind > 0:
        lines.append(f"⚠ {name}: behind={behind}（远程有更新）")
        warn += 1
    elif ahead > 0:
        lines.append(f"⚠ {name}: ahead={ahead}（有待推送 commit）")
        warn += 1
    elif dirty:
        lines.append(f"⚠ {name}: 有未提交变更")
        warn += 1
    else:
        lines.append(f"✓ {name}: 已同步")
print(json.dumps({"err": err, "warn": warn, "lines": lines}, ensure_ascii=False))
' 2>/dev/null || echo "parse_error")

  if [[ "$report" == "parse_error" || -z "$report" ]]; then
    ! $JSON && echo -e "  ${YELLOW}⚠${NC} sniff 输出解析失败"
    WARN_SYNC=1
    return 0
  fi

  ERR_SYNC=$(echo "$report" | python3 -c 'import json,sys;print(json.loads(sys.stdin.read())["err"])' 2>/dev/null || echo 0)
  WARN_SYNC=$(echo "$report" | python3 -c 'import json,sys;print(json.loads(sys.stdin.read())["warn"])' 2>/dev/null || echo 0)
  ERR_SYNC=${ERR_SYNC:-0}
  WARN_SYNC=${WARN_SYNC:-0}

  if ! $JSON; then
    echo "$report" | python3 -c '
import json, sys
d = json.loads(sys.stdin.read())
for l in d["lines"]:
    print(f"  {l}")
' 2>/dev/null || true
    echo -e "  ${DIM}→ ${ERR_SYNC} 错误, ${WARN_SYNC} 警告${NC}"
  fi
}

# ── Stage 4: CLI 寻址 (doctor_cli.py) ──
_stage_cli() {
  _in_scope cli || return 0

  ! $JSON && echo -e "\n${CYAN}[CLI 寻址]${NC}"
  local cli_script="$PRISM_DIR/skills/workflow/shared/scripts/doctor_cli.py"
  if [[ ! -f "$cli_script" ]]; then
    ! $JSON && echo -e "  ${YELLOW}⚠${NC} doctor_cli.py 不存在"
    WARN_CLI=$((WARN_CLI + 1))
    return 0
  fi

  local args=()
  $FIX && args+=("--fix")
  local out rc=0
  out=$(python3 "$cli_script" "${args[@]}" 2>&1) || rc=$?

  # doctor_cli 退出码: 0=ok, 1=error, 2=warn
  ERR_CLI=$(echo "$out" | python3 -c '
import json, sys
try:
    d = json.loads(sys.stdin.read())
    print(len(d.get("errors", [])))
except Exception:
    print(0)
' 2>/dev/null || echo 0)
  WARN_CLI=$(echo "$out" | python3 -c '
import json, sys
try:
    d = json.loads(sys.stdin.read())
    print(len(d.get("warnings", [])))
except Exception:
    print(0)
' 2>/dev/null || echo 0)
  FIX_CLI=$(echo "$out" | python3 -c '
import json, sys
try:
    d = json.loads(sys.stdin.read())
    print(len(d.get("fixes_applied", [])))
except Exception:
    print(0)
' 2>/dev/null || echo 0)
  ERR_CLI=${ERR_CLI:-0}
  WARN_CLI=${WARN_CLI:-0}
  FIX_CLI=${FIX_CLI:-0}

  if ! $JSON; then
    # 逐条打印 errors + warnings（用字面量 unicode 避免 f-string 反斜杠转义问题）
    echo "$out" | python3 -c '
import json, sys
try:
    d = json.loads(sys.stdin.read())
    for e in d.get("errors", []):
        print("  \u2717 [{0}] {1}".format(e.get("rule"), e.get("msg")))
    for w in d.get("warnings", []):
        print("  \u26a0 [{0}] {1}".format(w.get("rule"), w.get("msg")))
    for f in d.get("fixes_applied", []):
        print("  \u2713 \u5df2\u4fee\u590d [{0}] {1}".format(f.get("rule"), f.get("msg")))
except Exception:
    pass
' 2>/dev/null || true
    [[ $ERR_CLI -eq 0 && $WARN_CLI -eq 0 ]] && echo -e "  ${GREEN}✓${NC} 全部合规"
    echo -e "  ${DIM}→ ${ERR_CLI} 错误, ${WARN_CLI} 警告, ${FIX_CLI} 已修${NC}"
  fi
}

# ── Stage 5: 配置完整性 (prism.local.yaml 必填字段 + 路径可达性) ──
_stage_config() {
  _in_scope config || return 0

  ! $JSON && echo -e "\n${CYAN}[配置完整性]${NC}"
  local config_path="$PRISM_DIR/prism.local.yaml"

  if [[ ! -f "$config_path" ]]; then
    ! $JSON && echo -e "  ${RED}✗${NC} prism.local.yaml 不存在：$config_path"
    ERR_CONFIG=1
    return 0
  fi

  # 用 python 解析 yaml，检验 4 个必填字段 + 路径可达性
  local report
  report=$(python3 - "$config_path" <<'PYEOF' 2>/dev/null || echo "parse_error"
import json, os, sys

path = sys.argv[1]
try:
    with open(path, "r", encoding="utf-8") as f:
        raw = f.read()
except OSError as e:
    print(json.dumps({"err": 1, "warn": 0, "lines": [f"\u2717 \u8bfb\u53d6\u5931\u8d25: {e}"]}))
    sys.exit(0)

# 极简 YAML 解析：只处理顶层 key: value
config = {}
for line in raw.splitlines():
    line = line.rstrip()
    if not line or line.startswith("#") or line.startswith(" ") or line.startswith("-"):
        continue
    if ":" not in line:
        continue
    key, _, val = line.partition(":")
    config[key.strip()] = val.strip().strip('"').strip("'")

required = ["device_id", "sdk_path", "skills_path", "vault_path", "workspace_subdir"]
err = 0
warn = 0
lines = []
for field in required:
    if field not in config or not config[field]:
        lines.append(f"\u2717 \u7f3a\u5fc5\u586b\u5b57\u6bb5: {field}")
        err += 1

# 路径可达性
path_fields = ["sdk_path", "skills_path", "vault_path"]
for pf in path_fields:
    if pf in config and config[pf]:
        p = os.path.expanduser(config[pf])
        if not p.startswith("/"):
            lines.append(f"\u2717 {pf} \u975e\u7edd\u5bf9\u8def\u5f84: {p}")
            err += 1
        elif not os.path.isdir(p):
            # vault_path 在 iCloud 未同步时可能暂时不可达，记 WARN
            if pf == "vault_path":
                lines.append(f"\u26a0 {pf} \u4e0d\u53ef\u8fbe (iCloud \u672a\u540c\u6b65?): {p}")
                warn += 1
            else:
                lines.append(f"\u2717 {pf} \u76ee\u5f55\u4e0d\u5b58\u5728: {p}")
                err += 1

if err == 0 and warn == 0:
    lines.append("\u2713 5 \u5fc5\u586b\u5b57\u6bb5\u9f50\u5907\uff0c\u8def\u5f84\u5747\u53ef\u8fbe")

print(json.dumps({"err": err, "warn": warn, "lines": lines}, ensure_ascii=False))
PYEOF
)

  if [[ "$report" == "parse_error" || -z "$report" ]]; then
    ! $JSON && echo -e "  ${YELLOW}⚠${NC} 配置解析失败"
    WARN_CONFIG=1
    return 0
  fi

  ERR_CONFIG=$(echo "$report" | python3 -c 'import json,sys;print(json.loads(sys.stdin.read())["err"])' 2>/dev/null || echo 0)
  WARN_CONFIG=$(echo "$report" | python3 -c 'import json,sys;print(json.loads(sys.stdin.read())["warn"])' 2>/dev/null || echo 0)
  ERR_CONFIG=${ERR_CONFIG:-0}
  WARN_CONFIG=${WARN_CONFIG:-0}

  if ! $JSON; then
    echo "$report" | python3 -c '
import json, sys
d = json.loads(sys.stdin.read())
for l in d["lines"]:
    print(f"  {l}")
' 2>/dev/null || true
    echo -e "  ${DIM}→ ${ERR_CONFIG} 错误, ${WARN_CONFIG} 警告${NC}"
  fi
}

# ── 主流程 ───────────────────────────
if ! $JSON; then
  echo -e "${CYAN}Prism Doctor${NC}"
  echo "═══════════════════════════════════"
fi

_stage_env
_stage_skill
_stage_sync
_stage_cli
_stage_config

TOTAL_ERR=$((ERR_ENV + ERR_SKILL + ERR_SYNC + ERR_CLI + ERR_CONFIG))
TOTAL_WARN=$((WARN_ENV + WARN_SKILL + WARN_SYNC + WARN_CLI + WARN_CONFIG))
TOTAL_FIX=$((FIX_SKILL + FIX_CLI))

# ── 输出总结 ─────────────────────────
if $JSON; then
  cat <<EOF
{"errors":$TOTAL_ERR,"warnings":$TOTAL_WARN,"fixed":$TOTAL_FIX,"env":{"errors":$ERR_ENV,"warnings":$WARN_ENV},"skill":{"errors":$ERR_SKILL,"warnings":$WARN_SKILL,"fixed":$FIX_SKILL},"sync":{"errors":$ERR_SYNC,"warnings":$WARN_SYNC},"cli":{"errors":$ERR_CLI,"warnings":$WARN_CLI,"fixed":$FIX_CLI},"config":{"errors":$ERR_CONFIG,"warnings":$WARN_CONFIG}}
EOF
else
  echo ""
  echo "═══════════════════════════════════"
  if [[ $TOTAL_ERR -gt 0 ]]; then
    echo -e "${RED}✗ Doctor: ${TOTAL_ERR} 错误, ${TOTAL_WARN} 警告${NC}"
  elif [[ $TOTAL_WARN -gt 0 ]]; then
    echo -e "${YELLOW}⚠ Doctor: 0 错误, ${TOTAL_WARN} 警告${NC}"
    $FIX || echo -e "  ${DIM}提示: bin/doctor --fix 可自动修复部分问题${NC}"
  else
    echo -e "${GREEN}✓ Prism 环境完全健康${NC}"
  fi
fi

# 退出码
if [[ $TOTAL_ERR -gt 0 ]]; then exit 1
elif [[ $TOTAL_WARN -gt 0 ]]; then exit 2
else exit 0; fi
